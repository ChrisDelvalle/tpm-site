{
  "globs": ["**/*.md"],
  "ignores": [
    ".agents/skills/**",
    ".astro/**",
    ".lighthouseci/**",
    "coverage/**",
    "dist/**",
    "node_modules/**",
    "playwright-report/**",
    "test-results/**",
    "unused-assets/**"
  ],
  "config": {
    "MD013": false,
    "MD029": false,
    "MD034": false,
    "MD036": false,
    "MD037": false,
    "MD024": {
      "siblings_only": true
    },
    "MD033": false,
    "MD049": false,
    // TPM article citations use custom [^cite-*] labels that are validated by
    // the article-reference verifier instead of Markdown reference definitions.
    "MD052": false
  }
}

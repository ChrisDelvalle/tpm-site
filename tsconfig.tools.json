{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "types": ["bun", "node"]
  },
  "include": [
    ".astro/content.d.ts",
    ".astro/types.d.ts",
    "astro.config.mjs",
    "eslint.config.js",
    "lighthouserc.cjs",
    "playwright.config.ts",
    "scripts/**/*.ts",
    "tests/**/*.ts"
  ],
  "exclude": ["dist", "node_modules"]
}

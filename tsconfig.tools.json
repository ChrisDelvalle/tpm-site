{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "types": ["bun", "node"]
  },
  "include": [
    ".astro/content.d.ts",
    ".astro/types.d.ts",
    "astro.config.ts",
    "eslint/**/*.ts",
    "eslint.config.ts",
    "knip.ts",
    "playwright.config.ts",
    "scripts/**/*.ts",
    "tests/.env.catalog.test.ts",
    "tests/**/*.ts",
    "types/**/*.d.ts",
    "vitest.config.ts"
  ],
  "exclude": ["dist", "node_modules"]
}

{
  "name": "tpm-site",
  "version": "0.1.0",
  "private": true,
  "description": "Astro site for The Philosopher's Meme.",
  "type": "module",
  "scripts": {
    "assets:duplicates": "bun scripts/find-duplicate-images.ts",
    "assets:locations": "bun scripts/verify-image-asset-locations.ts",
    "assets:shared": "bun scripts/find-shared-assets.ts",
    "assets:unused": "bun scripts/find-unused-images.ts",
    "audit": "bun audit --audit-level=high",
    "audit:all": "bun audit",
    "build": "astro build && pagefind --site dist --quiet --glob \"{index.html,about/**/*.html,articles/**/*.html,authors/**/*.html,categories/**/*.html,search/**/*.html}\"",
    "catalog:build": "bun --env-file=.env.catalog --silent run build",
    "catalog:check": "bun scripts/verify-component-catalog.ts --quiet",
    "catalog:dev": "bun --env-file=.env.catalog --silent run dev",
    "catalog:preview": "bun --env-file=.env.catalog --silent run preview",
    "catalog:preview:fresh": "bun --env-file=.env.catalog --silent run build && bun --env-file=.env.catalog --silent run preview",
    "check": "bun --silent run verify:content -- --quiet && bun --silent run assets:locations -- --quiet && bun --silent run assets:shared -- --quiet && bun --silent run typecheck && bun --silent run lint && bun --silent run lint:packages && bun --silent run format && bun --silent run deadcode && bun --silent run catalog:check && bun --silent run test",
    "check:release": "bun --silent run test:accountability:release && bun --silent run check && bun --silent run build && bun --silent run verify && bun --silent run validate:html && bun --silent run test:e2e && bun --silent run test:catalog && bun --silent run audit && bun --silent run secrets",
    "coverage": "bun --silent run coverage:unit && bun --silent run coverage:verify",
    "coverage:check": "bun test tests/config tests/eslint tests/src tests/types tests/lib tests/scripts tests/components tests/pages --reporter=dots --randomize --coverage --coverage-reporter=lcov && bun --silent run coverage:verify",
    "coverage:unit": "bun test tests/config tests/eslint tests/src tests/types tests/lib tests/scripts tests/components tests/pages --randomize --coverage --coverage-reporter=text --coverage-reporter=lcov",
    "coverage:verify": "bun scripts/verify-test-coverage.ts --quiet",
    "deadcode": "knip --no-config-hints --no-progress",
    "dev": "astro dev",
    "fix": "bun --silent run lint:fix && bun --silent run format:write",
    "fix:markdown": "bun --silent run format:markdown:write",
    "format": "bun --silent run format:code",
    "format:code": "prettier --check \"**/*.{astro,css,cjs,js,json,jsonc,mjs,ts,tsx,yaml,yml}\" --log-level warn",
    "format:code:write": "prettier --write --list-different \"**/*.{astro,css,cjs,js,json,jsonc,mjs,ts,tsx,yaml,yml}\"",
    "format:markdown": "prettier --check \"**/*.{md,mdx}\" --log-level warn",
    "format:markdown:write": "prettier --write --list-different \"**/*.{md,mdx}\"",
    "format:write": "bun --silent run format:code:write",
    "lint": "eslint . --ignore-pattern \"**/*.md\" --ignore-pattern \"**/*.mdx\" --max-warnings=0 --no-cache",
    "lint:fix": "eslint . --ignore-pattern \"**/*.md\" --ignore-pattern \"**/*.mdx\" --fix --max-warnings=0 --no-cache",
    "lint:markdown": "markdownlint-cli2",
    "lint:mdx": "eslint \"src/content/articles/**/*.mdx\" --max-warnings=0 --no-cache",
    "lint:packages": "sort-package-json --check --quiet package.json",
    "preview": "astro preview",
    "preview:fresh": "bun --silent run build && bun --silent run preview",
    "quality": "bun scripts/run-quality.ts",
    "quality:release": "bun scripts/run-quality.ts --release",
    "review:assets": "bun --silent run assets:duplicates -- --review --quiet && bun --silent run assets:unused -- --review --quiet",
    "review:markdown": "bun --silent run lint:markdown && bun --silent run lint:mdx && bun --silent run format:markdown",
    "secrets": "gitleaks git --redact --no-banner",
    "test": "bun scripts/run-tests.ts",
    "test:a11y": "bun --silent run build && playwright test tests/a11y",
    "test:accountability": "bun scripts/verify-test-accountability.ts --quiet",
    "test:accountability:release": "bun scripts/verify-test-accountability.ts --quiet --release",
    "test:astro": "astro sync --force && bun scripts/sync-astro-test-store.ts && vitest run --config vitest.config.ts",
    "test:catalog": "bun --env-file=.env.catalog --silent run build && playwright test tests/e2e/catalog-invariants.spec.ts",
    "test:e2e": "bun --silent run build && playwright test tests/e2e",
    "test:flake": "bun --silent run test:unit -- --rerun-each 10",
    "test:perf": "bun --silent run build && lhci autorun",
    "test:unit": "bun test tests/config tests/eslint tests/src tests/types tests/lib tests/scripts tests/components tests/pages --reporter=dots --randomize --concurrent",
    "typecheck": "bun --silent run typecheck:astro && bun --silent run typecheck:tools",
    "typecheck:astro": "astro check --minimumFailingSeverity warning --minimumSeverity warning",
    "typecheck:tools": "tsc --project tsconfig.tools.json --pretty false",
    "validate:html": "html-validate --max-warnings=0 dist/index.html dist/404.html \"dist/about/**/*.html\" \"dist/articles/index.html\" \"dist/authors/**/*.html\" \"dist/categories/**/*.html\" \"dist/search/**/*.html\"",
    "verify": "bun scripts/verify-build.ts --quiet",
    "verify:content": "bun scripts/verify-content.ts"
  },
  "overrides": {
    "debug": "^4.4.3",
    "postcss": "^8.5.12",
    "sugarss": "^5.0.1",
    "tmp": "^0.2.5",
    "uuid": "^14.0.0",
    "yaml": "^2.8.3"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/react": "^5.0.4",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.2.1",
    "clsx": "^2.1.1",
    "lucide-astro": "^0.556.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.11.3",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bun": "^1.3.13",
    "@types/mdast": "^4.0.4",
    "@typescript-eslint/parser": "8.59.1",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-array-func": "^5.1.1",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-better-tailwindcss": "^4.5.0",
    "eslint-plugin-decorator-position": "^6.1.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-mdx": "^3.7.0",
    "eslint-plugin-no-only-tests": "^3.4.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-no-use-extend-native": "^0.7.3",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-playwright": "^2.10.2",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-perf": "^3.3.3",
    "eslint-plugin-react-prefer-function-component": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-security": "^4.0.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-ssr-friendly": "^1.3.0",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-toml": "^1.3.1",
    "eslint-plugin-total-functions": "^7.1.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-validate-jsx-nesting": "^0.1.1",
    "eslint-plugin-yml": "^3.3.2",
    "globals": "^17.5.0",
    "gray-matter": "^4.0.3",
    "happy-dom": "^20.9.0",
    "html-validate": "^10.13.1",
    "ignore": "^7.0.5",
    "knip": "^6.9.0",
    "markdownlint-cli2": "^0.22.1",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "rehype-stringify": "^10.0.1",
    "remark": "^15.0.1",
    "remark-gfm": "^4.0.1",
    "remark-rehype": "^11.1.2",
    "sort-package-json": "^3.6.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "unist-util-visit": "^5.1.0",
    "vitest": "^4.1.5"
  },
  "packageManager": "bun@1.3.12",
  "engines": {
    "node": ">=22.12.0"
  }
}

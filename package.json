{
  "name": "tpm-site",
  "version": "0.1.0",
  "private": true,
  "description": "Astro site for The Philosopher's Meme.",
  "type": "module",
  "scripts": {
    "audit": "bun audit --audit-level=high",
    "build": "bun run sync:content && ASTRO_TELEMETRY_DISABLED=1 astro build && pagefind --site dist",
    "check": "bun run verify:content && bun run typecheck && bun run lint && bun run lint:docs && bun run lint:packages && bun run format && bun run deadcode && bun run test",
    "check:release": "bun run check && bun run build && bun run verify && bun run validate:html && bun run test:e2e && bun run test:a11y && bun run test:perf && bun run coverage && bun run audit && bun run secrets",
    "coverage": "bun test tests/lib --randomize --concurrent --coverage --coverage-reporter=text --coverage-reporter=lcov",
    "deadcode": "knip --no-config-hints",
    "dev": "bun run sync:content && astro dev",
    "fix": "bun run lint:fix && bun run format:write",
    "format": "prettier --check . --log-level warn",
    "format:write": "prettier --write --list-different .",
    "lint": "eslint . --ext .js,.mjs,.cjs,.ts,.tsx,.astro,.mdx --max-warnings=0 --report-unused-disable-directives-severity error --no-cache",
    "lint:docs": "markdownlint-cli2",
    "lint:fix": "eslint . --ext .js,.mjs,.cjs,.ts,.tsx,.astro,.mdx --fix --max-warnings=0 --report-unused-disable-directives-severity error --no-cache",
    "lint:packages": "sort-package-json --check --quiet package.json",
    "migrate:articles:categories": "bun scripts/migrate-articles-to-categories.mjs",
    "migrate:articles:metadata": "bun scripts/normalize-article-metadata.mjs",
    "migrate:articles:rename": "bun scripts/rename-legacy-articles.mjs",
    "migrate:assets": "bun scripts/plan-asset-migration.mjs",
    "migrate:assets:write": "bun scripts/plan-asset-migration.mjs --write",
    "migrate:content:html": "bun scripts/normalize-markdown-html.mjs",
    "migrate:content:html:write": "bun scripts/normalize-markdown-html.mjs --write",
    "migrate:content:mdx-images": "bun scripts/migrate-raw-images-to-mdx.mjs",
    "migrate:content:mdx-images:write": "bun scripts/migrate-raw-images-to-mdx.mjs --write",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "secrets": "gitleaks git --redact --no-banner",
    "sync:content": "node scripts/sync-content.mjs",
    "test": "bun test tests/lib --reporter=dots --randomize --concurrent",
    "test:a11y": "bun run build && playwright test tests/a11y",
    "test:e2e": "bun run build && playwright test tests/e2e",
    "test:flake": "bun run test -- --rerun-each 10",
    "test:perf": "bun run build && lhci autorun",
    "typecheck": "bun run sync:content && ASTRO_TELEMETRY_DISABLED=1 astro check",
    "validate:html": "html-validate dist/index.html dist/404.html \"dist/about/**/*.html\" \"dist/articles/index.html\" \"dist/search/**/*.html\" \"dist/topics/**/*.html\"",
    "validate:links": "node scripts/verify-build.mjs",
    "verify": "node scripts/verify-build.mjs",
    "verify:content": "bun run sync:content && node scripts/verify-content.mjs"
  },
  "dependencies": {
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/react": "^5.0.4",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@tailwindcss/vite": "^4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "^6.1.9",
    "clsx": "^2.1.1",
    "lucide-astro": "^0.556.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@axe-core/playwright": "^4.11.2",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/bun": "^1.3.13",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-jsonc": "^3.1.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-mdx": "^3.7.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-sonarjs": "^4.0.3",
    "eslint-plugin-unicorn": "^64.0.0",
    "eslint-plugin-yml": "^3.3.1",
    "globals": "^17.5.0",
    "gray-matter": "^4.0.3",
    "html-validate": "^10.13.1",
    "knip": "^6.7.0",
    "markdownlint-cli2": "^0.22.1",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "sort-package-json": "^3.6.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.1"
  },
  "packageManager": "bun@1.3.12",
  "engines": {
    "node": ">=22.12.0"
  }
}

              </h2>
              <p class="text-muted-foreground">
                Layout frames preserve the content region while sidebar
                discovery remains reusable.
              </p>
            </PageFrame>
          </MainFrame>
        </div>
      </CatalogExample>

      <CatalogExample
        title="SiteFooter"
        description="Publication footer with categories and support action."
        componentPath="src/components/layout/SiteFooter.astro"
      >
        <SiteFooter navigationItems={catalogNavigationItems} />
      </CatalogExample>

      <CatalogExample
        title="PageFrame"
        description="Generic page content width and vertical rhythm."
        componentPath="src/components/layout/PageFrame.astro"
      >
        <PageFrame spacing="sm" size="prose">
          <p>
            PageFrame gives non-article pages a predictable responsive measure.
          </p>
        </PageFrame>
      </CatalogExample>
    </CatalogSection>
  </Container>
</main>

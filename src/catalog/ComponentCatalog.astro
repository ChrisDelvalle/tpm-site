const realAuthorProfiles = await getAuthorProfiles();
const [realAuthorProfile] = realAuthorProfiles;

if (realAuthorProfile === undefined) {
  throw new Error(
    "The component catalog requires at least one author profile.",
  );
}

const catalogAuthorProfile = {
  ...realAuthorProfile,
  shortBio:
    "Catalog-only profile metadata demonstrates optional author biography surfaces.",
  socials: [
    {
      href: "https://example.com/author-profile",
      label: "Profile",
    },
  ],
  website: "https://example.com",
};
const catalogAuthorProfiles = [
  catalogAuthorProfile,
  ...realAuthorProfiles
    .filter((profile) => profile.id !== catalogAuthorProfile.id)
    .slice(0, 3),
];
const catalogAuthorSummaries = catalogAuthorProfiles
  .slice(0, 2)
  .map(({ displayName, href, id, shortBio, type }) => ({
    displayName,
    href,
    id,
    shortBio,
    type,
  }));
const [primaryCatalogAuthor] = catalogAuthorSummaries;

if (primaryCatalogAuthor === undefined) {
  throw new Error(
    "The component catalog requires at least one author summary.",

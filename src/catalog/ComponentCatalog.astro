          </ActionCluster>
          <BrandLink slot="center" class="max-w-full text-sm sm:text-base" />
          <ActionCluster slot="end" align="end" gap="xs">
            <TextLink href="/articles/">Articles</TextLink>
            <LinkButton
              href="https://patreon.com/thephilosophersmeme"
              class="min-h-8 px-3 py-1.5 text-sm"
            >
              Support Us
            </LinkButton>
          </ActionCluster>
        </PriorityInlineRow>
      </CatalogExample>

      <CatalogExample
        title="SiteHeader"
        description="Responsive header composed from navigation primitives."
        componentPath="src/components/layout/SiteHeader.astro"
      >
        <SiteHeader
          currentPath="/articles/"
          categoryItems={catalogNavigationItems}
          primaryItems={primaryNavigationItems()}
        />
      </CatalogExample>

      <CatalogExample
        title="MainFrame"
        description="Desktop sidebar plus main content composition."
        componentPath="src/components/layout/MainFrame.astro"
      >
        <div class="max-h-96 overflow-hidden border">
          <MainFrame navigationItems={catalogNavigationItems}>
            <PageFrame spacing="sm">
              <h2 class="text-foreground text-xl font-semibold">

---
import type { HTMLAttributes } from "astro/types";

/** Public props for one curated component catalog example. */
interface Props extends HTMLAttributes<"article"> {
  componentPath?: string;
  description?: string;
  title: string;
}

const {
  title,
  description,
  componentPath,
  class: className,
  ...attrs
} = Astro.props;
---

<article
  {...attrs}
  class:list={[
    "border-border bg-card text-card-foreground grid min-w-0 gap-4 rounded-sm border p-4",
    className,
  ]}
>
  <header class="grid gap-1">
    <h3 class="text-foreground text-base font-semibold">{title}</h3>
    {
      description ? (
        <p class="text-muted-foreground text-sm">{description}</p>
      ) : null
    }
    {
      componentPath ? (
        <code class="text-muted-foreground text-xs">{componentPath}</code>
      ) : null
    }
  </header>
  <div class="border-border bg-background min-w-0 rounded-sm border p-4">
    <slot />
  </div>
</article>

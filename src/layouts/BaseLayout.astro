---
import "../styles/global.css";

import { Menu, Moon, Sun, X } from "lucide-astro";

import SiteHead from "../components/seo/SiteHead.astro";
import { getCategories } from "../lib/content";
import { categoryNavigationItems } from "../lib/navigation";
import { SITE_DESCRIPTION, SITE_TITLE } from "../lib/routes";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  image?: string | undefined;
  imageAlt?: string | undefined;
  type?: "website" | "article";
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  canonicalPath = Astro.url.pathname,
  image,
  imageAlt,
  type = "website",
} = Astro.props;
const sidebarCategories = categoryNavigationItems(
  await getCategories(),
  Astro.url.pathname,
);
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <script src="../scripts/theme.ts"></script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg?v=2" type="image/svg+xml" />
    <SiteHead
      canonicalPath={canonicalPath}
      description={description}
      image={image}
      imageAlt={imageAlt}
      title={title}
      type={type}
    />
    <slot name="head" />
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <div class="site-shell">
      <header class="site-header">
        <div class="header-left">
          <a class="brand" href="/">
            <span>{SITE_TITLE}</span>
          </a>
        </div>
        <form
          class="search-box"
          action="/search/"
          role="search"
          aria-label="Site search"
        >
          <label class="sr-only" for="site-search">Search</label>
          <input id="site-search" type="search" name="q" placeholder="Search" />
          <button class="sr-only" type="submit">Search</button>
        </form>
        <div class="header-right">
          <div class="header-nav-actions">
            <nav class="primary-nav" aria-label="Primary navigation">
              <a href="/articles/">Articles</a>
              <a href="/categories/">Categories</a>
              <a href="/about/">About</a>
              <a href="/feed.xml">RSS</a>
            </nav>
            <button
              class="theme-toggle"
              type="button"
              aria-label="Toggle dark mode"
            >
              <Sun class="theme-toggle-light" size={18} aria-hidden="true" />
              <Moon class="theme-toggle-dark" size={18} aria-hidden="true" />
            </button>
          </div>
          <a
            class="button header-support"
            href="https://patreon.com/thephilosophersmeme"
          >
            Support Us
          </a>
        </div>
        <details class="mobile-menu">
          <summary aria-label="Open navigation menu">
            <Menu class="mobile-menu-open" size={24} aria-hidden="true" />
            <X class="mobile-menu-close" size={24} aria-hidden="true" />
          </summary>
          <div class="mobile-menu-panel">
            <form
              class="mobile-search-box mobile-menu-search"
              action="/search/"
              role="search"
              aria-label="Mobile site search"
            >
              <label class="sr-only" for="mobile-site-search">Search</label>
              <input
                id="mobile-site-search"
                type="search"
                name="q"
                placeholder="Search"
              />
              <button class="sr-only" type="submit">Search</button>
            </form>
            <div class="mobile-menu-nav-actions">
              <nav
                class="mobile-primary-nav"
                aria-label="Mobile primary navigation"
              >
                <a href="/articles/">Articles</a>
                <a href="/categories/">Categories</a>
                <a href="/about/">About</a>
                <a href="/feed.xml">RSS</a>
              </nav>
              <button
                class="theme-toggle"
                type="button"
                aria-label="Toggle dark mode"
              >
                <Sun class="theme-toggle-light" size={18} aria-hidden="true" />
                <Moon class="theme-toggle-dark" size={18} aria-hidden="true" />
              </button>
            </div>
            <a
              class="button mobile-menu-support"
              href="https://patreon.com/thephilosophersmeme"
            >
              Support Us
            </a>
            <nav
              class="mobile-category-nav"
              aria-label="Mobile category navigation"
            >
              <strong>Categories</strong>
              {
                sidebarCategories.map((category) => (
                  <details class="category-group" open={category.isOpen}>
                    <summary>
                      <span>{category.title}</span>
                    </summary>
                    <ol>
                      {category.articles.map((article) => (
                        <li>
                          <a href={article.url}>{article.title}</a>
                        </li>
                      ))}
                    </ol>
                  </details>
                ))
              }
            </nav>
          </div>
        </details>
      </header>
      <div class="layout-grid">
        <aside class="sidebar" aria-label="Category navigation">
          <strong>Categories</strong>
          <nav class="category-nav" aria-label="Desktop category navigation">
            {
              sidebarCategories.map((category) => (
                <details class="category-group" open={category.isOpen}>
                  <summary>
                    <span>{category.title}</span>
                  </summary>
                  <ol>
                    {category.articles.map((article) => (
                      <li>
                        <a href={article.url}>{article.title}</a>
                      </li>
                    ))}
                  </ol>
                </details>
              ))
            }
          </nav>
        </aside>
        <main id="content">
          <slot />
        </main>
      </div>
      <footer class="site-footer">
        <span>Copyright &copy; {new Date().getFullYear()} {SITE_TITLE}</span>
        <a href="https://patreon.com/thephilosophersmeme"
          >Support Our Research</a
        >
      </footer>
    </div>
  </body>
</html>

---
import "../styles/global.css";

import { Menu, Moon, Sun, X } from "lucide-astro";

import { getArticles } from "../lib/content";
import {
  articleUrl,
  entryTitle,
  SITE_DESCRIPTION,
  SITE_TITLE,
  sourceFolder,
  TOPICS,
  topicUrl,
} from "../lib/routes";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  image?: string | undefined;
  type?: "website" | "article";
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  canonicalPath = Astro.url.pathname,
  image,
  type = "website",
} = Astro.props;
const canonicalUrl = new URL(canonicalPath, Astro.site);
const imageUrl = image ? new URL(image, Astro.site).toString() : undefined;
const articles = await getArticles();
const currentPath = Astro.url.pathname;
const sidebarTopics = TOPICS.map((topic) => {
  const topicArticles = articles.filter(
    (article) => sourceFolder(article) === topic.source,
  );
  const isCurrentTopic = currentPath.startsWith(topicUrl(topic.slug));
  const containsCurrentArticle = topicArticles.some((article) =>
    currentPath.startsWith(articleUrl(article.id)),
  );

  return {
    ...topic,
    articles: topicArticles,
    isOpen: isCurrentTopic || containsCurrentArticle,
  };
});
---

<!doctype html>
<html lang="en">
  <head>
    <script is:inline>
      const storedTheme = localStorage.getItem("theme");
      document.documentElement.dataset.theme = storedTheme || "dark";
    </script>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg?v=2" type="image/svg+xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE_TITLE} RSS`}
      href="/feed.xml"
    />
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    <meta
      name="twitter:card"
      content={imageUrl ? "summary_large_image" : "summary"}
    />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {imageUrl && <meta name="twitter:image" content={imageUrl} />}
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#content">Skip to content</a>
    <div class="site-shell">
      <header class="site-header">
        <div class="header-left">
          <a class="brand" href="/">
            <span>{SITE_TITLE}</span>
          </a>
        </div>
        <form
          class="search-box"
          action="/search/"
          role="search"
          aria-label="Site search"
        >
          <label class="sr-only" for="site-search">Search</label>
          <input id="site-search" type="search" name="q" placeholder="Search" />
          <button class="sr-only" type="submit">Search</button>
        </form>
        <div class="header-right">
          <div class="header-nav-actions">
            <nav class="primary-nav" aria-label="Primary navigation">
              <a href="/articles/">Articles</a>
              <a href="/topics/">Topics</a>
              <a href="/about/">About</a>
              <a href="/feed.xml">RSS</a>
            </nav>
            <button
              class="theme-toggle"
              type="button"
              aria-label="Toggle dark mode"
            >
              <Sun class="theme-toggle-light" size={18} aria-hidden="true" />
              <Moon class="theme-toggle-dark" size={18} aria-hidden="true" />
            </button>
          </div>
          <a
            class="button header-support"
            href="https://patreon.com/thephilosophersmeme"
          >
            Support Us
          </a>
        </div>
        <details class="mobile-menu">
          <summary aria-label="Open navigation menu">
            <Menu class="mobile-menu-open" size={24} aria-hidden="true" />
            <X class="mobile-menu-close" size={24} aria-hidden="true" />
          </summary>
          <div class="mobile-menu-panel">
            <form
              class="mobile-search-box mobile-menu-search"
              action="/search/"
              role="search"
              aria-label="Mobile site search"
            >
              <label class="sr-only" for="mobile-site-search">Search</label>
              <input
                id="mobile-site-search"
                type="search"
                name="q"
                placeholder="Search"
              />
              <button class="sr-only" type="submit">Search</button>
            </form>
            <div class="mobile-menu-nav-actions">
              <nav
                class="mobile-primary-nav"
                aria-label="Mobile primary navigation"
              >
                <a href="/articles/">Articles</a>
                <a href="/topics/">Topics</a>
                <a href="/about/">About</a>
                <a href="/feed.xml">RSS</a>
              </nav>
              <button
                class="theme-toggle"
                type="button"
                aria-label="Toggle dark mode"
              >
                <Sun class="theme-toggle-light" size={18} aria-hidden="true" />
                <Moon class="theme-toggle-dark" size={18} aria-hidden="true" />
              </button>
            </div>
            <a
              class="button mobile-menu-support"
              href="https://patreon.com/thephilosophersmeme"
            >
              Support Us
            </a>
            <nav class="mobile-topic-nav" aria-label="Mobile topic navigation">
              <strong>Topics</strong>
              {
                sidebarTopics.map((topic) => (
                  <details class="topic-group" open={topic.isOpen}>
                    <summary>
                      <span>{topic.label}</span>
                    </summary>
                    <ol>
                      {topic.articles.map((article) => (
                        <li>
                          <a href={articleUrl(article.id)}>
                            {entryTitle(article)}
                          </a>
                        </li>
                      ))}
                    </ol>
                  </details>
                ))
              }
            </nav>
          </div>
        </details>
      </header>
      <div class="layout-grid">
        <aside class="sidebar" aria-label="Topic navigation">
          <strong>Topics</strong>
          <nav class="topic-nav" aria-label="Desktop topic navigation">
            {
              sidebarTopics.map((topic) => (
                <details class="topic-group" open={topic.isOpen}>
                  <summary>
                    <span>{topic.label}</span>
                  </summary>
                  <ol>
                    {topic.articles.map((article) => (
                      <li>
                        <a href={articleUrl(article.id)}>
                          {entryTitle(article)}
                        </a>
                      </li>
                    ))}
                  </ol>
                </details>
              ))
            }
          </nav>
        </aside>
        <main id="content">
          <slot />
        </main>
      </div>
      <footer class="site-footer">
        <span>Copyright &copy; {new Date().getFullYear()} {SITE_TITLE}</span>
        <a href="https://patreon.com/thephilosophersmeme"
          >Support Our Research</a
        >
      </footer>
    </div>
    <script is:inline>
      const themeToggles = document.querySelectorAll(".theme-toggle");
      const setTheme = (theme) => {
        document.documentElement.dataset.theme = theme;
        localStorage.setItem("theme", theme);
      };

      themeToggles.forEach((themeToggle) => {
        themeToggle.addEventListener("click", () => {
          const currentTheme = document.documentElement.dataset.theme || "dark";
          setTheme(currentTheme === "dark" ? "light" : "dark");
        });
      });
    </script>
  </body>
</html>

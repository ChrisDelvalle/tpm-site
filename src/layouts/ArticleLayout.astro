---
import ArticleJsonLd from "../components/seo/ArticleJsonLd.astro";
import ArticleEndcap from "../components/articles/ArticleEndcap.astro";
import ArticleHeader from "../components/articles/ArticleHeader.astro";
import ArticleProse from "../components/articles/ArticleProse.astro";
import ArticleTags from "../components/articles/ArticleTags.astro";
import { articleListItemsFromArchive } from "../lib/article-list";
import { articleViewModel } from "../lib/article-view";
import { articleArchiveItems } from "../lib/archive";
import { getCategory } from "../lib/content";
import { categoryUrl, type ArticleEntry } from "../lib/routes";
import BaseLayout from "./BaseLayout.astro";

interface Props {
  article: ArticleEntry;
}

const { article } = Astro.props;
const articleView = articleViewModel(article);
const category = await getCategory(articleView.categorySlug);
const categoryHref = category ? categoryUrl(category.slug) : undefined;
const moreInCategory =
  category === undefined
    ? []
    : articleListItemsFromArchive(
        articleArchiveItems(
          category.articles
            .filter((categoryArticle) => categoryArticle.id !== article.id)
            .slice(0, 3),
          [category],
        ),
      );
---

<BaseLayout
  title={`${articleView.title} | The Philosopher's Meme`}
  description={articleView.description}
  canonicalPath={articleView.canonicalPath}
  image={articleView.image}
  imageAlt={articleView.imageAlt}
  type="article"
>
  <ArticleJsonLd slot="head" article={article} category={category} />
  <article
    class="mx-auto grid w-full max-w-3xl gap-8 px-4 py-8 lg:px-8 lg:py-12"
    data-pagefind-body
  >
    <ArticleHeader
      author={articleView.author}
      category={category && categoryHref
        ? { href: categoryHref, title: category.title }
        : undefined}
      date={articleView.date}
      description={articleView.description}
      formattedDate={articleView.formattedDate}
      title={articleView.title}
    />
    <ArticleProse data-article-prose>
      <slot />
    </ArticleProse>
    <ArticleEndcap
      categoryHref={categoryHref}
      categoryTitle={category?.title}
      moreInCategory={moreInCategory}
    />
    {
      article.data.tags.length > 0 && (
        <div class="border-border border-t pt-6" data-article-tags-placement>
          <ArticleTags tags={article.data.tags} />
        </div>
      )
    }
  </article>
</BaseLayout>

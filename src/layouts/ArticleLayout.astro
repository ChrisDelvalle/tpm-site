---
import ArticleJsonLd from "../components/seo/ArticleJsonLd.astro";
import ArticleProse from "../components/article/ArticleProse.astro";
import { getCategory } from "../lib/content";
import {
  articleUrl,
  authorName,
  categorySlug,
  categoryUrl,
  entryDate,
  entryTitle,
  excerpt,
  formatDate,
  imageUrl,
  type ArticleEntry,
} from "../lib/routes";
import BaseLayout from "./BaseLayout.astro";

interface Props {
  article: ArticleEntry;
}

const { article } = Astro.props;
const date = entryDate(article);
const description = excerpt(article);
const title = entryTitle(article);
const canonicalPath = articleUrl(article.id);
const category = await getCategory(categorySlug(article));
---

<BaseLayout
  title={`${title} | The Philosopher's Meme`}
  description={description}
  canonicalPath={canonicalPath}
  image={imageUrl(article)}
  imageAlt={article.data.imageAlt}
  type="article"
>
  <ArticleJsonLd slot="head" article={article} category={category} />
  <article class="article" data-pagefind-body>
    {
      category && (
        <a class="eyebrow" href={categoryUrl(category.slug)}>
          {category.title}
        </a>
      )
    }
    <h1>{title}</h1>
    <div class="article-meta">
      <span>{authorName(article)}</span>
      {date && <span>{formatDate(date)}</span>}
    </div>
    {description && <p class="lede">{description}</p>}
    <ArticleProse class="mt-8">
      <slot />
    </ArticleProse>
  </article>
</BaseLayout>

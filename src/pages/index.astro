---
import { getEntry, render } from "astro:content";

import recentImage from "../assets/shared/2020-06-24_fossilised-bug_resized.png";
import heroImage from "../assets/site/2022-04-05_tpm-header_trnp_dm.png";
import announcementImage from "../assets/site/r2021-03-22.png";
import HomeAnnouncementBlock from "../components/blocks/HomeAnnouncementBlock.astro";
import HomeArchiveLinksBlock from "../components/blocks/HomeArchiveLinksBlock.astro";
import HomeCategoryOverviewBlock from "../components/blocks/HomeCategoryOverviewBlock.astro";
import HomeFeaturedArticlesBlock from "../components/blocks/HomeFeaturedArticlesBlock.astro";
import HomeHeroBlock from "../components/blocks/HomeHeroBlock.astro";
import HomeLatestArticleBlock from "../components/blocks/HomeLatestArticleBlock.astro";
import SupportBlock from "../components/blocks/SupportBlock.astro";
import BrowsingBody from "../components/layout/BrowsingBody.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { articleListItemsFromArchive } from "../lib/article-list";
import { articleArchiveItems } from "../lib/archive";
import { getArticles, getCategories } from "../lib/content";
import { sectionNavigationItems } from "../lib/navigation";

const home = await getEntry("pages", "index");

if (!home) {
  throw new Error("Missing home page content at src/content/pages/index.md.");
}

const { Content } = await render(home);
const articles = await getArticles();
const categories = await getCategories();
const articleItems = articleListItemsFromArchive(
  articleArchiveItems(articles, categories),
);
const [latestArticle] = articleItems;
const featuredArticles = articleItems.slice(1, 4);
const categoryItems = sectionNavigationItems(categories, "/");

const title = `${home.data.title} | The Philosopher's Meme`;
const description =
  home.data.description ??
  "The philosophy of memes, cyberculture, and the Internet.";
---

<BaseLayout title={title} description={description} canonicalPath="/">
  <BrowsingBody width="wide">
    <HomeHeroBlock
      image={heroImage}
      imageAlt={home.data.title}
      tagline={description}
    />
    <HomeAnnouncementBlock
      image={announcementImage}
      imageAlt="The Philosopher's Meme announcement artwork"
    >
      <Content />
    </HomeAnnouncementBlock>
    <HomeLatestArticleBlock
      image={recentImage}
      imageAlt={latestArticle?.title ?? "Most recent article"}
      item={latestArticle}
    />
    <HomeFeaturedArticlesBlock items={featuredArticles} />
    <HomeCategoryOverviewBlock items={categoryItems} />
    <HomeArchiveLinksBlock />
    <SupportBlock />
  </BrowsingBody>
</BaseLayout>

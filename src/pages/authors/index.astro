---
import AuthorsIndexPage from "../../components/authors/AuthorsIndexPage.astro";
import BrowsingBody from "../../components/layout/BrowsingBody.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAuthorProfiles } from "../../lib/authors";
import { authorsIndexUrl } from "../../lib/routes";

const profiles = await getAuthorProfiles();
---

<BaseLayout
  title="Authors | The Philosopher's Meme"
  description="Browse contributors and collectives in The Philosopher's Meme archive."
  canonicalPath={authorsIndexUrl()}
>
  <BrowsingBody>
    <AuthorsIndexPage profiles={profiles} />
  </BrowsingBody>
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getArticles } from "../../lib/content";
import { sourceFolder, TOPICS, topicUrl } from "../../lib/routes";

const articles = await getArticles();
const topics = TOPICS.map((topic) => ({
  ...topic,
  count: articles.filter((entry) => sourceFolder(entry) === topic.source).length,
}));
---

<BaseLayout
  title="Topics | The Philosopher's Meme"
  description="Browse articles by topic."
  canonicalPath="/topics/"
>
  <section class="page-heading">
    <h1>Topics</h1>
    <p>Browse the archive by subject.</p>
  </section>

  <div class="topic-grid">
    {
      topics.map((topic) => (
        <a class="topic-card" href={topicUrl(topic.slug)}>
          <span>{topic.label}</span>
          <small>{topic.count} articles</small>
        </a>
      ))
    }
  </div>
</BaseLayout>

---
import { getEntry, render } from "astro:content";

import ReadingBody from "../components/layout/ReadingBody.astro";
import MarkdownPage from "../components/pages/MarkdownPage.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { pageUrl } from "../lib/routes";

const about = await getEntry("pages", "about");

if (!about) {
  throw new Error("Missing about page content at src/content/pages/about.md.");
}

const { Content } = await render(about);
const description = about.data.description ?? "About The Philosopher's Meme.";
---

<BaseLayout
  title={`${about.data.title} | The Philosopher's Meme`}
  description={description}
  canonicalPath={pageUrl("about")}
>
  <ReadingBody>
    <MarkdownPage title={about.data.title} description={description}>
      <Content />
    </MarkdownPage>
  </ReadingBody>
</BaseLayout>

---
import CategoryOverviewBlock from "../../components/blocks/CategoryOverviewBlock.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCategories } from "../../lib/content";
import { sectionNavigationItems } from "../../lib/navigation";

const categoryItems = sectionNavigationItems(
  await getCategories(),
  "/categories/",
);
---

<BaseLayout
  title="Categories | The Philosopher's Meme"
  description="Browse articles by category."
  canonicalPath="/categories/"
>
  <CategoryOverviewBlock
    title="Categories"
    description="Browse the archive by subject."
    items={categoryItems}
  />
</BaseLayout>

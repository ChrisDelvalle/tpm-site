---
import { render } from "astro:content";

import ArticleHeader from "../../components/articles/ArticleHeader.astro";
import ArticleProse from "../../components/articles/ArticleProse.astro";
import ReadingBody from "../../components/layout/ReadingBody.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAnnouncements } from "../../lib/content";
import {
  announcementUrl,
  formatDate,
  type AnnouncementEntry,
} from "../../lib/routes";
import { announcementStaticPaths } from "../../lib/static-paths";

/**
 * Generates one static announcement route for each published announcement.
 *
 * @returns Static route parameters and announcement props for Astro.
 */
export async function getStaticPaths() {
  return announcementStaticPaths(await getAnnouncements());
}

interface Props {
  announcement: AnnouncementEntry;
}

const { announcement } = Astro.props;
const { Content } = await render(announcement);
const title = announcement.data.title;
const description = announcement.data.description;
---

<BaseLayout
  title={`${title} | The Philosopher's Meme`}
  description={description}
  canonicalPath={announcementUrl(announcement.id)}
  image={announcement.data.image?.src}
  imageAlt={announcement.data.imageAlt}
  type="article"
>
  <ReadingBody>
    <article class="grid w-full min-w-0 gap-8" data-pagefind-body>
      <ArticleHeader
        author={announcement.data.author}
        date={announcement.data.date}
        description={description}
        formattedDate={formatDate(announcement.data.date)}
        title={title}
      />
      <ArticleProse data-article-prose>
        <Content />
      </ArticleProse>
    </article>
  </ReadingBody>
</BaseLayout>

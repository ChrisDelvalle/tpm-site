---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getArticles, getCategories } from "../../lib/content";
import {
  articleUrl,
  authorName,
  categorySlug,
  categoryUrl,
  entryDate,
  entryTitle,
  excerpt,
  formatDate,
} from "../../lib/routes";

const articles = await getArticles();
const categories = await getCategories();
const categoryMap = new Map(
  categories.map((category) => [category.slug, category] as const),
);
---

<BaseLayout
  title="Articles | The Philosopher's Meme"
  description="Complete article archive for The Philosopher's Meme."
  canonicalPath="/articles/"
>
  <section class="page-heading">
    <h1>Articles</h1>
    <p>Essays and notes on memes, cyberculture, and the Internet.</p>
  </section>

  <ol class="archive-list" data-pagefind-ignore>
    {
      articles.map((article) => {
        const category = categoryMap.get(categorySlug(article));
        return (
          <li>
            <a class="archive-title" href={articleUrl(article.id)}>
              {entryTitle(article)}
            </a>
            <div class="archive-meta">
              <span>{formatDate(entryDate(article))}</span>
              <span>{authorName(article)}</span>
              {category && (
                <a href={categoryUrl(category.slug)}>{category.title}</a>
              )}
            </div>
            {excerpt(article) && <p>{excerpt(article)}</p>}
          </li>
        );
      })
    }
  </ol>
</BaseLayout>

---
import { render } from "astro:content";

import ArticleLayout from "../../layouts/ArticleLayout.astro";
import { articleTableOfContentsHeadings } from "../../lib/article-toc";
import { getArticles } from "../../lib/content";
import { articleStaticPaths } from "../../lib/static-paths";
import { articleReferencesFromFrontmatter } from "../../remark-plugins/articleReferences";

/**
 * Generates one static article route for each published article.
 *
 * @returns Static route parameters and article props for Astro.
 */
export async function getStaticPaths() {
  return articleStaticPaths(await getArticles());
}

const { article } = Astro.props;
const { Content, headings, remarkPluginFrontmatter } = await render(article);
const articleReferences = articleReferencesFromFrontmatter(
  remarkPluginFrontmatter,
);
const tableOfContentsHeadings = articleTableOfContentsHeadings(headings);
---

<ArticleLayout
  article={article}
  articleReferences={articleReferences}
  tableOfContentsHeadings={tableOfContentsHeadings}
>
  <Content />
</ArticleLayout>

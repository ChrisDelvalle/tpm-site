---
import TextLink from "../ui/TextLink.astro";
import type { SectionNavItem as SectionNavItemData } from "../../lib/navigation";

interface Props {
  item: SectionNavItemData;
}

const { item } = Astro.props;
const hasCurrentArticle = item.articles.some((article) => article.isCurrent);
---

<li>
  <details class="group grid gap-2" open={item.isOpen}>
    <summary
      class="text-foreground hover:text-primary focus-visible:outline-ring flex cursor-pointer list-none items-center justify-between gap-3 rounded-xs py-1 text-sm font-semibold transition-colors focus-visible:outline-2 focus-visible:outline-offset-2 [&::-webkit-details-marker]:hidden"
    >
      <span>{item.title}</span>
      <span
        class:list={[
          "text-muted-foreground text-xs transition-transform group-open:rotate-90",
          hasCurrentArticle && "text-primary",
        ]}
        aria-hidden="true"
      >
        &rsaquo;
      </span>
    </summary>
    <ol class="border-border ms-2 grid gap-1 border-s ps-3">
      <li>
        <TextLink
          href={item.href}
          variant="subtle"
          tone={item.isCurrent || hasCurrentArticle ? "primary" : "muted"}
          prefetch="tap"
          aria-current={item.isCurrent ? "page" : undefined}
          class="text-xs"
        >
          View all {item.title}
        </TextLink>
      </li>
      {
        item.articles.map((article) => (
          <li>
            <TextLink
              href={article.href}
              variant="subtle"
              tone={article.isCurrent ? "primary" : "muted"}
              prefetch="tap"
              aria-current={article.isCurrent ? "page" : undefined}
              class="line-clamp-2 text-xs"
            >
              {article.title}
            </TextLink>
          </li>
        ))
      }
    </ol>
  </details>
</li>

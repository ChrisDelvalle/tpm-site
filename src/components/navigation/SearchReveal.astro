---
import { Search } from "lucide-astro";

import AnchoredPanel from "../ui/AnchoredPanel.astro";
import AnchoredRoot from "../ui/AnchoredRoot.astro";
import AnchoredTrigger from "../ui/AnchoredTrigger.astro";
import SearchForm from "./SearchForm.astro";

interface Props {
  align?: "end" | "start";
  label?: string;
  popoverId?: string;
}

const {
  align = "start",
  label = "Open search",
  popoverId = "site-search-reveal",
} = Astro.props;
const preset = align === "end" ? "header-search-end" : "header-search-start";
---

<AnchoredRoot preset={preset} data-search-reveal>
  <AnchoredTrigger
    as="button"
    type="button"
    popovertarget={popoverId}
    data-search-reveal-trigger
    class="text-muted-foreground hover:text-foreground focus-visible:outline-ring inline-flex size-10 items-center justify-center rounded-xs transition-colors focus-visible:outline-2 focus-visible:outline-offset-2"
    aria-label={label}
  >
    <Search class="size-5" aria-hidden="true" />
  </AnchoredTrigger>
  <AnchoredPanel
    id={popoverId}
    popover="auto"
    data-search-reveal-panel
    class="border-border bg-popover text-popover-foreground m-0 w-[min(26rem,calc(100vw-2rem))] rounded-sm border p-3 shadow-lg"
  >
    <SearchForm inputId={`${popoverId}-input`} label="Site search" />
  </AnchoredPanel>
</AnchoredRoot>

<script src="./search-reveal.ts"></script>

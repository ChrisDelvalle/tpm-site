---
import CategoryDropdown from "./CategoryDropdown.astro";
import type { SectionNavItem } from "../../lib/navigation";

interface Props {
  currentPath?: string;
  items: readonly SectionNavItem[];
  label?: string;
}

const { currentPath = "", items, label = "Category discovery" } = Astro.props;
---

{
  items.length > 0 && (
    <nav
      aria-label={label}
      class="hidden h-full w-full min-w-0 items-center justify-center overflow-visible md:flex"
      data-discovery-menu
    >
      <ul
        class="flex h-full w-full max-w-5xl min-w-0 flex-nowrap items-center justify-center gap-1 overflow-hidden"
        data-discovery-menu-list
      >
        {items.map((item) => (
          <li class="flex min-w-0 flex-1 basis-0 justify-center">
            <CategoryDropdown
              category={item}
              currentPath={currentPath}
              previewId={`category-discovery-${item.slug}`}
            />
          </li>
        ))}
      </ul>
    </nav>
  )
}

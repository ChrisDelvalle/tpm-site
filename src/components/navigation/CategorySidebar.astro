---
import CategoryTree from "./CategoryTree.astro";
import type { SectionNavItem } from "../../lib/navigation";

interface Props {
  heading?: string;
  items: readonly SectionNavItem[];
  label?: string;
  treeLabel?: string;
}

const {
  heading = "Categories",
  items,
  label = "Category navigation",
  treeLabel = "Desktop category navigation",
} = Astro.props;
---

<aside
  class="border-border bg-sidebar text-sidebar-foreground sticky top-[var(--site-header-height)] max-h-[calc(100dvh-var(--site-header-height))] overflow-y-auto border-e px-4 py-6"
  aria-label={label}
>
  <div class="grid gap-4">
    <strong class="text-primary text-xs font-semibold uppercase"
      >{heading}</strong
    >
    <CategoryTree items={items} label={treeLabel} />
  </div>
</aside>

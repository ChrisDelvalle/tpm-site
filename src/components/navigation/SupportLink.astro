---
import type { HTMLAttributes } from "astro/types";
import LinkButton from "../ui/LinkButton.astro";

interface Props extends Omit<HTMLAttributes<"a">, "href"> {
  class?: string;
  href?: string;
  label?: string;
}

const {
  class: className,
  href = "https://patreon.com/thephilosophersmeme",
  label = "Support Us",
  ...attrs
} = Astro.props;
---

<LinkButton
  {...attrs}
  href={href}
  size="md"
  class:list={[className]}
  data-support-link
>
  {label}
</LinkButton>

---
import type { HTMLAttributes } from "astro/types";

import TextLink from "../ui/TextLink.astro";

interface ReadingNavigationLink {
  href: string;
  label: string;
}

interface Props extends HTMLAttributes<"nav"> {
  links: readonly ReadingNavigationLink[];
  showTitle?: boolean;
  title?: string;
}

const {
  links,
  showTitle = true,
  title = "Read",
  class: className,
  ...attrs
} = Astro.props;
const prefetchAttrsFor = (href: string) =>
  href.startsWith("/") ? { prefetch: "hover" as const } : {};
---

<nav
  {...attrs}
  class:list={[
    "text-muted-foreground flex w-fit max-w-full min-w-0 flex-nowrap items-center gap-x-2 overflow-hidden py-0 text-xs sm:gap-x-3 sm:text-sm",
    className,
  ]}
>
  {
    showTitle && (
      <>
        <span class="text-foreground shrink-0 font-semibold whitespace-nowrap">
          {title}
        </span>
        <span aria-hidden="true">/</span>
      </>
    )
  }
  <ul class="flex min-w-0 flex-nowrap gap-x-2 overflow-hidden sm:gap-x-3">
    {
      links.map((link) => (
        <li class="min-w-0 shrink">
          <TextLink
            href={link.href}
            variant="subtle"
            tone="muted"
            class="block truncate whitespace-nowrap"
            {...prefetchAttrsFor(link.href)}
          >
            {link.label}
          </TextLink>
        </li>
      ))
    }
  </ul>
</nav>

---
import CategoryPreviewList from "./CategoryPreviewList.astro";
import TextLink from "../ui/TextLink.astro";
import type { SectionNavItem } from "../../lib/navigation";

interface Props {
  category: SectionNavItem;
  currentPath?: string;
  popoverId: string;
}

const { category, currentPath = "", popoverId } = Astro.props;
const isCurrent = currentPath.startsWith(category.href);
const anchorName = `--${popoverId}`;
---

<div class="relative" data-category-dropdown={category.slug}>
  <button
    type="button"
    popovertarget={popoverId}
    class:list={[
      "rounded-xs px-1 py-1 text-sm font-medium tracking-normal transition-colors",
      "focus-visible:outline-ring focus-visible:outline-2 focus-visible:outline-offset-2",
      isCurrent
        ? "text-primary hover:text-primary/80"
        : "text-muted-foreground hover:text-foreground",
    ]}
    aria-label={`Browse ${category.title} articles`}
    style={`anchor-name: ${anchorName};`}
  >
    {category.title}
  </button>
  <div
    id={popoverId}
    popover="auto"
    class="border-border bg-popover text-popover-foreground m-0 mt-3 max-h-[min(32rem,calc(100dvh-6rem))] w-[min(22rem,calc(100vw-2rem))] overflow-y-auto rounded-sm border p-4 shadow-lg"
    style={`position: absolute; position-anchor: ${anchorName}; inset: auto; top: calc(anchor(bottom) + 0.75rem); left: anchor(left);`}
  >
    <div class="grid gap-3">
      <div class="grid gap-1">
        <TextLink
          href={category.href}
          tone={isCurrent ? "primary" : "neutral"}
          aria-current={isCurrent ? "page" : undefined}
        >
          {category.title}
        </TextLink>
        {
          category.description && (
            <p class="text-muted-foreground text-xs">{category.description}</p>
          )
        }
      </div>
      <CategoryPreviewList
        articles={category.articles}
        categoryHref={category.href}
        categoryTitle={category.title}
      />
    </div>
  </div>
</div>

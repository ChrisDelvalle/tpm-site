---
import { ChevronDown } from "lucide-astro";

import CategoryPreviewList from "./CategoryPreviewList.astro";
import type { SectionNavItem } from "../../lib/navigation";

interface Props {
  category: SectionNavItem;
  currentPath?: string;
  previewId: string;
}

const { category, currentPath = "", previewId } = Astro.props;
const isCurrent =
  currentPath.startsWith(category.href) ||
  category.articles.some((article) => article.isCurrent);
---

<div class="group relative" data-category-dropdown={category.slug}>
  <a
    href={category.href}
    class:list={[
      "inline-flex items-center gap-1 rounded-xs px-1 py-1 text-sm font-medium tracking-normal transition-colors",
      "focus-visible:outline-ring focus-visible:outline-2 focus-visible:outline-offset-2",
      isCurrent
        ? "text-primary hover:text-primary/80"
        : "text-muted-foreground hover:text-foreground",
    ]}
    aria-current={isCurrent ? "page" : undefined}
  >
    <span>{category.title}</span>
    <ChevronDown
      class="size-3 transition-transform group-focus-within:rotate-180 group-hover:rotate-180"
      aria-hidden="true"
    />
  </a>
  <div
    class="fixed inset-x-4 top-[calc(var(--site-header-height)+0.25rem)] z-50 hidden pt-2 group-focus-within:block group-hover:block"
    data-floating-panel
  >
    <div
      id={previewId}
      class="border-border bg-popover text-popover-foreground mx-auto grid max-h-[calc(100dvh-var(--site-header-height)-2rem)] w-full max-w-sm gap-3 overflow-y-auto rounded-sm border p-4 shadow-lg"
      data-category-preview
    >
      <CategoryPreviewList
        articles={category.articles}
        categoryHref={category.href}
        categoryTitle={category.title}
      />
    </div>
  </div>
</div>

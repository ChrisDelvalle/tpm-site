---
import { ChevronDown } from "lucide-astro";

import AnchoredPanel from "../ui/AnchoredPanel.astro";
import AnchoredRoot from "../ui/AnchoredRoot.astro";
import AnchoredTrigger from "../ui/AnchoredTrigger.astro";
import CategoryPreviewList from "./CategoryPreviewList.astro";
import type { SectionNavItem } from "../../lib/navigation";

interface Props {
  category: SectionNavItem;
  currentPath?: string;
  previewId: string;
}

const { category, currentPath = "", previewId } = Astro.props;
const isCurrent =
  currentPath.startsWith(category.href) ||
  category.articles.some((article) => article.isCurrent);
---

<AnchoredRoot
  preset="header-dropdown"
  class="group relative"
  data-category-dropdown={category.slug}
>
  <AnchoredTrigger
    as="a"
    href={category.href}
    class:list={[
      "inline-flex items-center gap-1 rounded-xs px-1 py-1 text-sm font-medium tracking-normal transition-colors",
      "focus-visible:outline-ring focus-visible:outline-2 focus-visible:outline-offset-2",
      isCurrent
        ? "text-primary hover:text-primary/80"
        : "text-muted-foreground hover:text-foreground",
    ]}
    aria-current={isCurrent ? "page" : undefined}
  >
    <span>{category.title}</span>
    <ChevronDown
      class="size-3 transition-transform group-focus-within:rotate-180 group-hover:rotate-180"
      aria-hidden="true"
    />
  </AnchoredTrigger>
  <AnchoredPanel
    id={previewId}
    class="border-border bg-popover text-popover-foreground z-50 hidden w-[min(24rem,var(--anchor-max-width,calc(100vw-2rem)))] gap-3 overflow-y-auto rounded-sm border p-4 shadow-lg group-focus-within:grid group-hover:grid before:fixed before:inset-x-0 before:top-[calc(var(--anchor-y,0rem)-1rem)] before:h-4 before:content-['']"
    data-category-preview
  >
    <CategoryPreviewList
      articles={category.articles}
      categoryHref={category.href}
      categoryTitle={category.title}
    />
  </AnchoredPanel>
</AnchoredRoot>

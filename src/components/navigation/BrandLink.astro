---
import TextLink from "../ui/TextLink.astro";
import { SITE_TITLE } from "../../lib/routes";

interface Props {
  href?: string;
  label?: string;
}

const { href = "/", label = SITE_TITLE } = Astro.props;
---

<TextLink
  href={href}
  variant="nav"
  tone="neutral"
  class="inline-flex min-w-0 items-center text-lg font-bold"
>
  <span class="truncate">{label}</span>
</TextLink>

---
import type { HTMLAttributes } from "astro/types";
import TextLink from "../ui/TextLink.astro";
import { SITE_TITLE } from "../../lib/routes";

interface Props extends Omit<HTMLAttributes<"a">, "href"> {
  class?: string;
  href?: string;
  label?: string;
}

const {
  class: className,
  href = "/",
  label = SITE_TITLE,
  "aria-label": ariaLabel = label,
  ...attrs
} = Astro.props;
---

<TextLink
  {...attrs}
  href={href}
  aria-label={ariaLabel}
  variant="nav"
  tone="neutral"
  prefetch="hover"
  class:list={["inline-flex items-center text-lg font-bold", className]}
  data-brand-link
>
  <span class="truncate" data-brand-label>
    {label}
  </span>
</TextLink>

---
import TextLink from "../ui/TextLink.astro";
import type { ArticleSummary } from "../../lib/navigation";

interface Props {
  articles: readonly ArticleSummary[];
  categoryHref: string;
  categoryTitle: string;
  maxItems?: number;
}

const { articles, categoryHref, categoryTitle, maxItems = 3 } = Astro.props;
const previewArticles = articles.slice(0, maxItems);
---

{
  previewArticles.length > 0 ? (
    <ol class="grid gap-2" data-category-preview-list>
      {previewArticles.map((article) => (
        <li>
          <TextLink href={article.href} tone="neutral">
            {article.title}
          </TextLink>
          <p class="text-muted-foreground mt-1 line-clamp-2 text-xs">
            {article.description}
          </p>
        </li>
      ))}
    </ol>
  ) : (
    <p class="text-muted-foreground text-sm" data-category-preview-empty>
      No article previews are available. View all {categoryTitle} articles.
    </p>
  )
}

<TextLink href={categoryHref} tone="primary" variant="subtle">
  View all {categoryTitle}
</TextLink>

---
import TextLink from "../ui/TextLink.astro";
import {
  articlesIndexUrl,
  categoriesIndexUrl,
  pageUrl,
} from "../../lib/routes";

interface PrimaryNavItem {
  href: string;
  label: string;
}

interface Props {
  currentPath?: string;
  items?: readonly PrimaryNavItem[];
  label?: string;
}

const {
  currentPath = "",
  items = [
    { href: articlesIndexUrl(), label: "Articles" },
    { href: categoriesIndexUrl(), label: "Categories" },
    { href: pageUrl("about"), label: "About" },
  ],
  label = "Primary navigation",
} = Astro.props;
---

<nav aria-label={label}>
  <ul class="flex flex-nowrap items-center gap-x-4 text-sm font-medium">
    {
      items.map((item) => {
        const isCurrent = currentPath.startsWith(item.href);

        return (
          <li>
            <TextLink
              href={item.href}
              variant="nav"
              tone={isCurrent ? "primary" : "muted"}
              aria-current={isCurrent ? "page" : undefined}
            >
              {item.label}
            </TextLink>
          </li>
        );
      })
    }
  </ul>
</nav>

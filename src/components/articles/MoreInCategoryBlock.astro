---
import ArticleList from "./ArticleList.astro";
import SectionHeader from "../ui/SectionHeader.astro";
import type { ArticleListItem } from "../../lib/article-list";

interface Props {
  categoryHref?: string | undefined;
  categoryTitle?: string | undefined;
  headingId?: string;
  items?: readonly ArticleListItem[] | undefined;
}

const {
  categoryHref,
  categoryTitle,
  headingId = "more-in-category-heading",
  items = [],
} = Astro.props;
---

{
  items.length > 0 && (
    <section
      class="grid w-full max-w-full min-w-0 gap-4"
      aria-labelledby={headingId}
    >
      <SectionHeader
        headingId={headingId}
        title={`More${categoryTitle ? ` in ${categoryTitle}` : ""}`}
        actionHref={categoryHref && categoryTitle ? categoryHref : undefined}
        actionLabel={
          categoryHref && categoryTitle ? "View category" : undefined
        }
      />
      <ArticleList items={items} />
    </section>
  )
}

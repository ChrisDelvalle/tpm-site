---
import MoreInCategoryBlock from "./MoreInCategoryBlock.astro";
import NextArticleBlock from "./NextArticleBlock.astro";
import RelatedArticlesBlock from "./RelatedArticlesBlock.astro";
import SupportBlock from "../blocks/SupportBlock.astro";
import type { ArticleListItem } from "../../lib/article-list";

interface Props {
  categoryHref?: string | undefined;
  categoryTitle?: string | undefined;
  continuity?:
    | undefined
    | {
        item: ArticleListItem;
        label: "Next Article" | "Previous Article";
      };
  idPrefix?: string;
  moreInCategory?: readonly ArticleListItem[] | undefined;
  related?: readonly ArticleListItem[] | undefined;
}

const {
  categoryHref,
  categoryTitle,
  continuity,
  idPrefix = "article-endcap",
  moreInCategory = [],
  related = [],
} = Astro.props;
---

<aside
  class="grid w-full max-w-full min-w-0 gap-8"
  aria-label="Article support and discovery"
  data-pagefind-ignore
>
  {
    continuity !== undefined ? (
      <NextArticleBlock
        headingId={`${idPrefix}-continuity-heading`}
        item={continuity.item}
        label={continuity.label}
      />
    ) : null
  }
  <SupportBlock headingId={`${idPrefix}-support-heading`} />
  <MoreInCategoryBlock
    categoryHref={categoryHref}
    categoryTitle={categoryTitle}
    headingId={`${idPrefix}-more-in-category-heading`}
    items={moreInCategory}
  />
  <RelatedArticlesBlock
    headingId={`${idPrefix}-related-articles-heading`}
    items={related}
  />
</aside>

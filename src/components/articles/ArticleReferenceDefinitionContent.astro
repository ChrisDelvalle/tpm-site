---
import type {
  ArticleReferenceBlockContent,
  ArticleReferenceInlineContent,
} from "../../lib/article-references/model";
import ArticleReferenceInlineContentNode from "./ArticleReferenceInlineContent.astro";

interface Props {
  blocks: readonly ArticleReferenceBlockContent[];
}

const { blocks } = Astro.props;

function hasInlineChildren(
  block: ArticleReferenceBlockContent,
): block is ArticleReferenceBlockContent & {
  children: readonly ArticleReferenceInlineContent[];
} {
  return "children" in block && block.children !== undefined;
}
---

<div
  class="grid max-w-full min-w-0 gap-3 break-words"
  data-article-reference-definition-content
>
  {
    blocks.map((block) =>
      block.kind === "code" ? (
        <pre class="border-border bg-muted max-w-full min-w-0 overflow-x-auto border p-3 text-sm">
          <code>{block.text}</code>
        </pre>
      ) : block.kind === "heading" ? (
        <p class="text-foreground max-w-full min-w-0 font-semibold break-words">
          {block.children.map((child) => (
            <ArticleReferenceInlineContentNode content={child} />
          ))}
        </p>
      ) : hasInlineChildren(block) ? (
        <p
          class:list={[
            "max-w-full min-w-0 break-words",
            block.kind === "list" && "pl-4",
          ]}
        >
          {block.children.map((child) => (
            <ArticleReferenceInlineContentNode content={child} />
          ))}
        </p>
      ) : (
        <p class="max-w-full min-w-0 break-words">{block.text}</p>
      ),
    )
  }
</div>

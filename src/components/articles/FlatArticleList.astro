---
import CompactEntryList from "./CompactEntryList.astro";
import TextLink from "../ui/TextLink.astro";
import type { PublishableListItem } from "../../lib/article-list";
import { htmlIdFromText } from "../../lib/html";

interface Props {
  emptyText?: string;
  headingLevel?: 2 | 3;
  items: readonly PublishableListItem[];
  title: string;
  titleHref?: string | undefined;
}

const {
  emptyText = "Items will appear here.",
  headingLevel = 2,
  items,
  title,
  titleHref,
} = Astro.props;
const headingId = `${htmlIdFromText(title, "article-list")}-heading`;
---

<section
  class="grid min-w-0 content-start gap-4"
  aria-labelledby={headingId}
  data-flat-article-list
>
  {
    headingLevel === 2 ? (
      <h2
        id={headingId}
        class="text-foreground m-0 text-2xl font-semibold tracking-normal"
      >
        {titleHref === undefined ? (
          title
        ) : (
          <TextLink
            href={titleHref}
            tone="neutral"
            variant="nav"
            prefetch="hover"
            class="font-semibold"
          >
            {title}
          </TextLink>
        )}
      </h2>
    ) : (
      <h3
        id={headingId}
        class="text-foreground m-0 text-lg font-semibold tracking-normal"
      >
        {titleHref === undefined ? (
          title
        ) : (
          <TextLink
            href={titleHref}
            tone="neutral"
            variant="nav"
            prefetch="hover"
            class="font-semibold"
          >
            {title}
          </TextLink>
        )}
      </h3>
    )
  }
  {(<CompactEntryList items={items} emptyText={emptyText} />)}
</section>

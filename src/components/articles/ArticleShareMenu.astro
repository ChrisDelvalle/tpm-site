---
import { Share2 } from "lucide-astro";

import ArticleHeaderActionTrigger from "./ArticleHeaderActionTrigger.astro";
import ArticleShareActionRow from "./ArticleShareActionRow.astro";
import type { ArticleShareMenuViewModel } from "../../lib/share-targets";
import ActionPopover from "../ui/ActionPopover.astro";

interface Props {
  share: ArticleShareMenuViewModel;
}

const { share } = Astro.props;
const shareDomId = share.articleUrl.replace(/[^\w-]/gu, "-");
const popoverId = `article-share-menu-${shareDomId}`;
const statusId = `article-share-${shareDomId}-status`;
const panelLabel = `Share ${share.title}`;
const copyText = JSON.stringify(share.copyText);
---

<ActionPopover
  preset="article-action-menu"
  popoverId={popoverId}
  panelLabel={panelLabel}
  panelWidth="18rem"
  panelAttributes={{
    "data-article-share-panel": true,
  }}
  data-article-share-menu
  class="relative inline-flex min-w-0"
>
  <ArticleHeaderActionTrigger
    slot="trigger"
    popovertarget={popoverId}
    label="Share this article"
    data-article-share-trigger
  >
    <Share2 class="size-3.5" aria-hidden="true" />
    <span aria-hidden="true">Share</span>
  </ArticleHeaderActionTrigger>
  <div class="grid min-w-0 gap-1">
    {
      share.actions.map((action) => (
        <ArticleShareActionRow
          action={action}
          copyText={copyText}
          statusId={statusId}
        />
      ))
    }
  </div>
  <p
    id={statusId}
    class="text-muted-foreground min-w-0 px-2 text-xs empty:hidden"
    aria-live="polite"
    data-article-share-copy-status
  >
  </p>
</ActionPopover>

<script src="../../scripts/article-share.ts"></script>

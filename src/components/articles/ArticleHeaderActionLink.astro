---
import type { HTMLAttributes } from "astro/types";

import { articleHeaderActionClasses } from "./article-header-actions";
import TextLink from "../ui/TextLink.astro";

/** Internal link action for article header controls such as PDF downloads. */
interface Props extends HTMLAttributes<"a"> {
  href: string;
  label: string;
}

const {
  href,
  label,
  class: className,
  "aria-label": ariaLabel = label,
  ...attrs
} = Astro.props;
---

<TextLink
  {...attrs}
  href={href}
  variant="nav"
  tone="muted"
  aria-label={ariaLabel}
  class:list={[articleHeaderActionClasses, className]}
>
  <slot />
</TextLink>

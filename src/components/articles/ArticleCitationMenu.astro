---
import { Copy, Quote } from "lucide-astro";

import type { ArticleCitationMenuViewModel } from "../../lib/citations/article-citation";
import AnchoredPanel from "../ui/AnchoredPanel.astro";
import AnchoredRoot from "../ui/AnchoredRoot.astro";
import AnchoredTrigger from "../ui/AnchoredTrigger.astro";

interface Props {
  citation: ArticleCitationMenuViewModel;
}

const { citation } = Astro.props;
const citationDomId = citation.articleId.replace(/[^\w-]/gu, "-");
const [initialFormat] = citation.formats;
const initialCopyText = JSON.stringify(initialFormat?.text ?? "");
const initialLines = initialFormat?.text.split("\n") ?? [];
const initialCopyLabel =
  initialFormat === undefined
    ? "Copy citation"
    : `Copy ${initialFormat.label} citation`;
const popoverId = `article-citation-menu-${citationDomId}`;
const statusId = `article-citation-${citationDomId}-status`;
const textId = `article-citation-${citationDomId}-selected`;
const citationTextClass =
  "border-border bg-background text-foreground relative block w-full min-w-0 max-w-full rounded-sm border py-2 ps-3 pe-12 font-mono text-xs leading-5 whitespace-pre-wrap break-words";
---

<AnchoredRoot
  preset="article-citation-menu"
  data-article-citation-menu
  class="relative ml-auto inline-flex min-w-0"
>
  <AnchoredTrigger
    as="button"
    type="button"
    popovertarget={popoverId}
    aria-label="Cite this article"
    data-article-citation-trigger
    class="text-muted-foreground hover:text-foreground focus-visible:outline-ring inline-flex items-center gap-1 rounded-xs text-sm leading-5 font-medium tracking-normal transition-colors focus-visible:outline-2 focus-visible:outline-offset-2"
  >
    <Quote class="size-3.5" aria-hidden="true" />
    <span aria-hidden="true">Cite</span>
  </AnchoredTrigger>
  <AnchoredPanel
    id={popoverId}
    popover="auto"
    aria-label={`Citation formats for ${citation.title}`}
    data-article-citation-panel
    class="border-border bg-popover text-popover-foreground z-50 m-0 grid w-[min(30rem,var(--anchor-max-width,calc(100vw-2rem)))] min-w-0 gap-1 overflow-y-auto rounded-sm border p-2 shadow-lg [&:not(:popover-open)]:hidden"
    style="width: min(30rem, var(--anchor-max-width, calc(100vw - 2rem)));"
  >
    <div
      class="border-border bg-border grid w-full min-w-0 grid-cols-4 gap-px overflow-hidden rounded-sm border"
      role="group"
      aria-label="Citation style"
      data-article-citation-style-selector
    >
      {
        citation.formats.map((format, index) => {
          const copyText = JSON.stringify(format.text);

          return (
            <button
              type="button"
              aria-pressed={index === 0 ? "true" : "false"}
              class="bg-popover text-muted-foreground hover:bg-muted hover:text-foreground focus-visible:outline-ring aria-pressed:bg-primary aria-pressed:text-primary-foreground inline-flex min-h-8 min-w-0 items-center justify-center px-2 py-1 text-center text-xs font-medium tracking-normal transition-colors focus-visible:z-10 focus-visible:outline-2 focus-visible:outline-offset-0"
              data-article-citation-format-id={format.id}
              data-article-citation-format-label={format.label}
              data-article-citation-format-text={copyText}
              data-article-citation-style-button
            >
              {format.label}
            </button>
          );
        })
      }
    </div>
    <div class="grid w-full min-w-0 gap-2">
      <div class:list={[citationTextClass]} data-article-citation-text-block>
        <code
          id={textId}
          data-article-citation-copy-text={initialCopyText}
          data-article-citation-text
          class="block max-w-full min-w-0"
        >
          {
            initialLines.map((line) => (
              <span class="block max-w-full min-w-0">
                {line.length === 0 ? "\u00A0" : line}
              </span>
            ))
          }
        </code>
        <button
          type="button"
          class="border-border bg-background text-muted-foreground hover:bg-muted hover:text-foreground focus-visible:outline-ring data-[article-citation-copy-state=copied]:text-primary absolute top-1.5 right-1.5 inline-flex size-7 shrink-0 items-center justify-center rounded-sm border transition-colors focus-visible:outline-2 focus-visible:outline-offset-2"
          aria-describedby={statusId}
          aria-label={initialCopyLabel}
          data-article-citation-copy-button
          data-article-citation-copy-target={textId}
        >
          <Copy class="size-4" aria-hidden="true" />
        </button>
      </div>
      <p
        id={statusId}
        class="text-muted-foreground min-w-0 text-xs empty:hidden"
        aria-live="polite"
        data-article-citation-copy-status
      >
      </p>
    </div>
  </AnchoredPanel>
</AnchoredRoot>

<script src="../../scripts/article-citation-copy.ts"></script>

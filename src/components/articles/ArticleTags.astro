---
import Badge from "../ui/Badge.astro";

interface Props {
  tags?: readonly string[] | undefined;
}

const { tags = [] } = Astro.props;
---

{
  tags.length > 0 && (
    <ul class="flex flex-wrap gap-2" aria-label="Article tags">
      {tags.map((tag) => (
        <li>
          <Badge tone="muted" variant="outline">
            {tag}
          </Badge>
        </li>
      ))}
    </ul>
  )
}

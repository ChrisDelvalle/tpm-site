---
import Badge from "../ui/Badge.astro";
import { tagUrl } from "../../lib/routes";

interface Props {
  tags?: readonly string[] | undefined;
}

const { tags = [] } = Astro.props;
---

{
  tags.length > 0 && (
    <ul class="flex min-w-0 flex-wrap gap-2" aria-label="Article tags">
      {tags.map((tag) => (
        <li>
          <a
            href={tagUrl(tag)}
            data-astro-prefetch="hover"
            class="focus-visible:outline-ring rounded-sm no-underline transition-opacity hover:opacity-80 focus-visible:outline-2 focus-visible:outline-offset-2"
          >
            <Badge tone="muted" variant="outline">
              {tag}
            </Badge>
          </a>
        </li>
      ))}
    </ul>
  )
}

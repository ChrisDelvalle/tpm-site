---
import ArticleList from "./ArticleList.astro";
import type { ArticleListItem } from "../../lib/article-list";

interface Props {
  headingId?: string;
  items?: readonly ArticleListItem[] | undefined;
}

const { headingId = "related-articles-heading", items = [] } = Astro.props;
---

{
  items.length > 0 && (
    <section class="grid gap-4" aria-labelledby={headingId}>
      <h2
        id={headingId}
        class="text-foreground m-0 text-xl font-semibold tracking-normal"
      >
        Related Articles
      </h2>
      <ArticleList items={items} />
    </section>
  )
}

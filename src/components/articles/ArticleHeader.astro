---
import { Download } from "lucide-astro";

import ArticleCitationMenu from "./ArticleCitationMenu.astro";
import ArticleMeta from "./ArticleMeta.astro";
import ArticleShareMenu from "./ArticleShareMenu.astro";
import TextLink from "../ui/TextLink.astro";
import type { AuthorSummary } from "../../lib/authors";
import type { ArticlePdfViewModel } from "../../lib/article-pdf";
import type { ArticleCitationMenuViewModel } from "../../lib/citations/article-citation";
import type { ArticleShareMenuViewModel } from "../../lib/share-targets";

interface ArticleCategory {
  href: string;
  title: string;
}

interface Props {
  author?: string | undefined;
  authors?: readonly AuthorSummary[] | undefined;
  category?: ArticleCategory | undefined;
  citation?: ArticleCitationMenuViewModel | undefined;
  date?: Date | undefined;
  description?: string | undefined;
  formattedDate?: string | undefined;
  pdf?: ArticlePdfViewModel | undefined;
  share?: ArticleShareMenuViewModel | undefined;
  title: string;
}

const {
  author,
  authors = [],
  category,
  citation,
  date,
  description,
  formattedDate,
  pdf,
  share,
  title,
} = Astro.props;
const hasHeaderActions =
  citation !== undefined || share !== undefined || pdf !== undefined;
const hasKickerRow = category !== undefined || hasHeaderActions;
---

<header class="grid min-w-0 gap-4">
  {
    hasKickerRow && (
      <div
        class:list={[
          "flex w-full max-w-4xl min-w-0 flex-wrap items-center gap-x-4 gap-y-2",
          category === undefined ? "justify-end" : "justify-between",
        ]}
        data-article-kicker-row
      >
        {category && (
          <TextLink
            href={category.href}
            variant="subtle"
            tone="primary"
            prefetch="hover"
            class="text-sm font-semibold uppercase"
            data-article-category-link
            data-pdf-exclude
          >
            {category.title}
          </TextLink>
        )}
        {hasHeaderActions && (
          <div
            class="ml-auto flex flex-wrap items-center gap-2 print:hidden"
            data-article-header-actions
            data-pdf-exclude
          >
            {citation && <ArticleCitationMenu citation={citation} />}
            {share && <ArticleShareMenu share={share} />}
            {pdf && (
              <TextLink
                href={pdf.pdfHref}
                variant="nav"
                tone="muted"
                class="inline-flex items-center gap-1 text-sm font-medium"
                aria-label="Save PDF"
                data-article-pdf-link
                download
              >
                <Download class="size-3.5" aria-hidden="true" />
                <span aria-hidden="true">PDF</span>
              </TextLink>
            )}
          </div>
        )}
      </div>
    )
  }
  <h1
    class="text-foreground m-0 max-w-4xl min-w-0 text-4xl font-bold tracking-normal break-words"
  >
    {title}
  </h1>
  <div
    class="flex w-full max-w-4xl min-w-0 flex-wrap items-start gap-x-4 gap-y-1"
    data-article-meta-row
  >
    <ArticleMeta
      author={author}
      authors={authors}
      date={date}
      formattedDate={formattedDate}
    />
  </div>
  {
    description && (
      <p class="text-muted-foreground max-w-3xl min-w-0 text-lg break-words">
        {description}
      </p>
    )
  }
  {
    pdf && (
      <>
        <p
          class="hidden text-sm leading-6 print:block"
          data-article-pdf-canonical
        >
          Published {formattedDate ?? pdf.publicationDateForScholar}. Available
          at <a href={pdf.articleUrl}>{pdf.articleUrl}</a>.
        </p>
        <p
          class="hidden text-sm leading-6 print:block"
          data-article-pdf-disclaimer
        >
          This PDF is a static export of the canonical web article. Interactive
          media and embeds may be represented as source links; visit the
          canonical article for the full web version.
        </p>
      </>
    )
  }
</header>

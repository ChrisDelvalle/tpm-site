---
import ArticleMeta from "./ArticleMeta.astro";
import TextLink from "../ui/TextLink.astro";

interface ArticleCategory {
  href: string;
  title: string;
}

interface Props {
  author?: string | undefined;
  category?: ArticleCategory | undefined;
  date?: Date | undefined;
  description?: string | undefined;
  formattedDate?: string | undefined;
  title: string;
}

const { author, category, date, description, formattedDate, title } =
  Astro.props;
---

<header class="grid gap-4">
  {
    category && (
      <TextLink
        href={category.href}
        variant="subtle"
        tone="primary"
        class="text-sm font-semibold uppercase"
      >
        {category.title}
      </TextLink>
    )
  }
  <h1 class="text-foreground m-0 max-w-4xl text-4xl font-bold tracking-normal">
    {title}
  </h1>
  <ArticleMeta author={author} date={date} formattedDate={formattedDate} />
  {
    description && (
      <p class="text-muted-foreground max-w-3xl text-lg">{description}</p>
    )
  }
</header>

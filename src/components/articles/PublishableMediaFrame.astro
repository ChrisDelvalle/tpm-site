---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import type { HTMLAttributes } from "astro/types";

type PrefetchValue = "hover" | "load" | "tap" | "viewport" | boolean;

interface PublishableImage {
  alt: string;
  src: ImageMetadata;
}

interface Props extends HTMLAttributes<"a"> {
  fallbackLabel?: string | undefined;
  href: string;
  image?: PublishableImage | undefined;
  imageClass?: string | undefined;
  label: string;
  loading?: "eager" | "lazy" | undefined;
  prefetch?: PrefetchValue | undefined;
  renderHeight: number;
  renderWidth: number;
}

const {
  fallbackLabel,
  href,
  image,
  imageClass = "h-full w-full object-cover",
  label,
  loading = "lazy",
  prefetch,
  renderHeight,
  renderWidth,
  class: className,
  "aria-label": ariaLabel,
  ...attrs
} = Astro.props;
const prefetchAttrs =
  prefetch === undefined ? {} : { "data-astro-prefetch": prefetch };
---

<a
  {...attrs}
  {...prefetchAttrs}
  href={href}
  aria-label={ariaLabel ?? label}
  class:list={[
    "block min-w-0 overflow-hidden rounded-xs no-underline",
    className,
  ]}
  data-publishable-media-frame
  data-publishable-media-has-image={image === undefined ? "false" : "true"}
>
  {
    image ? (
      <Image
        src={image.src}
        alt={image.alt}
        width={renderWidth}
        height={renderHeight}
        loading={loading}
        class:list={[imageClass]}
      />
    ) : (
      <span
        class="flex h-full w-full items-center justify-center p-4 text-center text-4xl leading-none font-bold tracking-normal uppercase"
        data-publishable-media-fallback
      >
        <span class="line-clamp-2 break-words">{fallbackLabel ?? label}</span>
      </span>
    )
  }
</a>

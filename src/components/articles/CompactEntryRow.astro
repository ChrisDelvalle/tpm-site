---
import type { HTMLAttributes } from "astro/types";

import EntryMetaLine from "./EntryMetaLine.astro";
import {
  compactEntryMetaItems,
  compactEntryPrefetch,
  type CompactEntryItem,
} from "./compact-entry";
import TextLink from "../ui/TextLink.astro";

interface Props extends HTMLAttributes<"article"> {
  descriptionLines?: 1 | 2 | 3;
  item: CompactEntryItem;
  showDescription?: boolean;
  titleLevel?: 3 | 4;
}

const {
  descriptionLines = 2,
  item,
  showDescription = false,
  titleLevel = 3,
  class: className,
  ...attrs
} = Astro.props;
const TitleTag = `h${titleLevel}` as const;
const metaItems = compactEntryMetaItems(item);
const prefetch = compactEntryPrefetch(item);
const prefetchAttrs = prefetch === undefined ? {} : { prefetch };
const descriptionClamp = {
  1: "line-clamp-1",
  2: "line-clamp-2",
  3: "line-clamp-3",
} as const;
---

<article
  {...attrs}
  class:list={["grid min-w-0 gap-1", className]}
  data-compact-entry-row
>
  <TitleTag
    class="text-foreground m-0 line-clamp-2 min-w-0 text-sm leading-6 font-semibold tracking-normal"
  >
    <TextLink
      href={item.href}
      variant="subtle"
      tone="neutral"
      {...prefetchAttrs}
    >
      {item.title}
    </TextLink>
  </TitleTag>
  <EntryMetaLine items={metaItems} class="m-0" data-compact-entry-meta />
  {
    showDescription && item.description && (
      <p
        class:list={[
          "text-muted-foreground m-0 min-w-0 text-xs leading-5",
          descriptionClamp[descriptionLines],
        ]}
        data-compact-entry-description
      >
        {item.description}
      </p>
    )
  }
</article>

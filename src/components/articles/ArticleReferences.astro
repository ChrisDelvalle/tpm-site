---
import type { ArticleReferenceData } from "../../lib/article-references/model";
import ArticleBibliography from "./ArticleBibliography.astro";
import ArticleFootnotes from "./ArticleFootnotes.astro";

interface Props {
  headingIdPrefix?: string;
  references: ArticleReferenceData;
  siteBibliographyHref?: string | undefined;
  siteBibliographyLabel?: string | undefined;
}

const {
  headingIdPrefix = "article-references",
  references,
  siteBibliographyHref,
  siteBibliographyLabel,
} = Astro.props;
const hasNotes = references.notes.length > 0;
const hasCitations = references.citations.length > 0;
---

{
  (hasNotes || hasCitations) && (
    <div class="border-border grid gap-8 border-t pt-8" data-article-references>
      <ArticleFootnotes
        headingId={`${headingIdPrefix}-notes-heading`}
        notes={references.notes}
      />
      <ArticleBibliography
        citations={references.citations}
        headingId={`${headingIdPrefix}-bibliography-heading`}
        siteBibliographyHref={siteBibliographyHref}
        siteBibliographyLabel={siteBibliographyLabel}
      />
      <div
        aria-label="Reference preview"
        class="border-border bg-popover text-popover-foreground fixed z-50 hidden w-[min(28rem,var(--anchor-max-width,calc(100vw-2rem)))] max-w-[calc(100vw-2rem)] overflow-y-auto rounded-sm border p-4 text-sm leading-relaxed shadow-lg"
        data-article-reference-preview
        data-pagefind-ignore
        hidden
        role="dialog"
        style="left: var(--anchor-x, 1rem); top: var(--anchor-y, 1rem); max-height: var(--anchor-max-height, calc(100dvh - 2rem));"
        tabindex="-1"
      >
        <div
          class="[&_a]:text-primary grid max-w-full min-w-0 gap-3 break-words [&_a]:underline [&_a]:underline-offset-4"
          data-article-reference-preview-content
        />
      </div>
      <script src="../../scripts/article-reference-previews.ts" />
    </div>
  )
}

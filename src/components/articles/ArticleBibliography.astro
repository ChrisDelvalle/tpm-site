---
import type { ArticleCitation } from "../../lib/article-references/model";
import ArticleReferenceBacklinks from "./ArticleReferenceBacklinks.astro";
import ArticleReferenceDefinitionContent from "./ArticleReferenceDefinitionContent.astro";

interface Props {
  citations: readonly ArticleCitation[];
  heading?: string;
  headingId?: string;
}

const {
  citations,
  heading = "Bibliography",
  headingId = "article-bibliography-heading",
} = Astro.props;
---

{
  citations.length > 0 && (
    <section class="grid gap-4" aria-labelledby={headingId}>
      <h2 id={headingId} class="text-foreground text-2xl font-semibold">
        {heading}
      </h2>
      <ol class="grid list-decimal gap-5 pl-6">
        {citations.map((citation) => (
          <li
            id={citation.id}
            value={citation.order}
            class="target:bg-muted scroll-mt-28 pl-2 break-words"
          >
            <div class="grid gap-3">
              <ArticleReferenceDefinitionContent
                blocks={citation.definition.children}
              />
              <ArticleReferenceBacklinks
                kind="citation"
                references={citation.references}
              />
            </div>
          </li>
        ))}
      </ol>
    </section>
  )
}

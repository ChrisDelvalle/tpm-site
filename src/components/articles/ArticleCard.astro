---
import type { ImageMetadata } from "astro";

import ArticleCardBody from "./ArticleCardBody.astro";
import PublishableMediaFrame from "./PublishableMediaFrame.astro";
import type { AuthorSummary } from "../../lib/authors";

interface ArticleCardCategory {
  href: string;
  title: string;
}

interface Props {
  author?: string | undefined;
  authors?: readonly AuthorSummary[] | undefined;
  category?: ArticleCardCategory | undefined;
  date?: string | undefined;
  description?: string | undefined;
  href: string;
  image?:
    | undefined
    | {
        alt: string;
        src: ImageMetadata;
      };
  title: string;
}

const {
  author,
  authors = [],
  category,
  date,
  description,
  href,
  image,
  title,
} = Astro.props;

const hasImage = image !== undefined;
const rowGridClasses = hasImage
  ? "grid-cols-[minmax(0,1fr)_5rem] sm:grid-cols-[minmax(0,1fr)_6rem] md:grid-cols-[minmax(0,1fr)_15rem] lg:grid-cols-[minmax(0,1fr)_18rem]"
  : "grid-cols-1";
---

<article
  class:list={[
    "group/article grid min-h-28 w-full max-w-full min-w-0 items-center gap-4 md:min-h-44 md:gap-8",
    rowGridClasses,
  ]}
  data-article-card
  data-article-card-has-image={hasImage ? "true" : "false"}
>
  {
    image && (
      <PublishableMediaFrame
        href={href}
        label={`Read ${title}`}
        image={image}
        renderWidth={640}
        renderHeight={360}
        prefetch="hover"
        data-article-card-image-link
        class="bg-muted focus-visible:outline-ring order-last size-20 justify-self-end transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 sm:size-24 md:h-40 md:w-60 lg:h-44 lg:w-72"
      />
    )
  }
  <ArticleCardBody
    author={author}
    authors={authors}
    category={category}
    date={date}
    description={description}
    hasImage={hasImage}
    href={href}
    title={title}
  />
</article>

---
import ArticleMeta from "./ArticleMeta.astro";
import Card from "../ui/Card.astro";
import TextLink from "../ui/TextLink.astro";
import type { AuthorSummary } from "../../lib/authors";

interface ArticleCardCategory {
  href: string;
  title: string;
}

interface Props {
  author?: string | undefined;
  authors?: readonly AuthorSummary[] | undefined;
  category?: ArticleCardCategory | undefined;
  date?: string | undefined;
  description?: string | undefined;
  href: string;
  title: string;
}

const {
  author,
  authors = [],
  category,
  date,
  description,
  href,
  title,
} = Astro.props;
---

<Card as="article" class="grid gap-3">
  <div class="grid min-w-0 gap-2">
    <h2
      class="text-foreground m-0 min-w-0 text-xl font-semibold tracking-normal break-words"
    >
      <TextLink href={href} variant="subtle" tone="neutral">{title}</TextLink>
    </h2>
    <ArticleMeta author={author} authors={authors} formattedDate={date} />
  </div>
  {
    category && (
      <TextLink
        href={category.href}
        variant="subtle"
        tone="primary"
        class="text-sm"
      >
        {category.title}
      </TextLink>
    )
  }
  {
    description && (
      <p class="text-muted-foreground min-w-0 text-sm break-words">
        {description}
      </p>
    )
  }
</Card>

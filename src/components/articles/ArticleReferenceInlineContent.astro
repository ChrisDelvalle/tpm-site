---
import type { ArticleReferenceInlineContent as InlineContent } from "../../lib/article-references/model";

interface Props {
  content: InlineContent;
}

const { content } = Astro.props;

function inlineText(node: InlineContent): string {
  if ("children" in node && node.children !== undefined) {
    return node.children.map(inlineText).join("");
  }

  return node.text;
}
---

{
  content.kind === "text" ? (
    content.text
  ) : content.kind === "inlineCode" ? (
    <code class="bg-muted rounded-sm px-1 py-0.5 text-[0.9em]">
      {content.text}
    </code>
  ) : content.kind === "break" ? (
    <br />
  ) : content.kind === "link" ? (
    <a
      class="text-primary focus-visible:outline-ring break-words underline underline-offset-4 focus-visible:outline-2 focus-visible:outline-offset-2"
      href={content.url}
      title={content.title}
    >
      {content.children.map(inlineText).join("")}
    </a>
  ) : content.kind === "emphasis" ? (
    <em>{content.children.map(inlineText).join("")}</em>
  ) : content.kind === "strong" ? (
    <strong>{content.children.map(inlineText).join("")}</strong>
  ) : (
    content.text
  )
}

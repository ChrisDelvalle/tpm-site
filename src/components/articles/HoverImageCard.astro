---
import type { ImageMetadata } from "astro";

import AnchoredPanel from "../ui/AnchoredPanel.astro";
import AnchoredRoot from "../ui/AnchoredRoot.astro";
import AnchoredTrigger from "../ui/AnchoredTrigger.astro";

/** Public props for inline article hover-image previews. */
interface Props {
  alt?: string;
  expanded?: boolean;
  image: ImageMetadata;
  label: string;
}

const { image, label, alt = "", expanded = false } = Astro.props;
const maxWidthRem = expanded ? 40 : 30;
const maxHeightRem = expanded ? 34 : 28;
const aspectRatio = aspectRatioOrFallback(image);
const displayWidthRem = Math.min(maxWidthRem, maxHeightRem * aspectRatio);
const imageStyle = [
  `--hover-image-width: ${displayWidthRem.toFixed(3)}rem;`,
  `--hover-image-max-height: ${maxHeightRem}rem;`,
].join(" ");

function aspectRatioOrFallback(image: ImageMetadata): number {
  if (image.width <= 0 || image.height <= 0) {
    return 1;
  }

  return image.width / image.height;
}
---

<AnchoredRoot
  preset="inline-hover-preview"
  class="group/hover-image inline"
  data-hover-image-card
  data-hover-image-expanded={expanded ? "true" : "false"}
>
  <AnchoredTrigger
    as="a"
    href={image.src}
    data-hover-image-trigger
    aria-label={`Open image preview: ${label}`}
  >
    {label}
  </AnchoredTrigger>
  <AnchoredPanel
    data-hover-image-panel
    class="ring-border/45 z-50 hidden overflow-hidden rounded-xs shadow-lg ring-1 group-focus-within/hover-image:block group-hover/hover-image:block before:fixed before:top-[calc(var(--anchor-y,0rem)-0.5rem)] before:left-[var(--anchor-x,0rem)] before:h-2 before:w-[min(var(--hover-image-width),var(--anchor-max-width,calc(100vw-2rem)))] before:content-['']"
    style={imageStyle}
  >
    <img
      src={image.src}
      alt={alt}
      width={image.width}
      height={image.height}
      loading="lazy"
      decoding="async"
      class="!m-0 block h-auto max-h-[min(var(--hover-image-max-height),var(--anchor-max-height,calc(100svh-2rem)))] w-[min(var(--hover-image-width),var(--anchor-max-width,calc(100vw-2rem)))] max-w-none object-contain"
    />
  </AnchoredPanel>
</AnchoredRoot>

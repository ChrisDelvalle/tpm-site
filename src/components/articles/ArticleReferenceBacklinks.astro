---
import type {
  ArticleReferenceKind,
  ArticleReferenceMarker,
} from "../../lib/article-references/model";

interface Props {
  kind: ArticleReferenceKind;
  references: readonly ArticleReferenceMarker[];
}

const { kind, references } = Astro.props;
const label = kind === "citation" ? "citation" : "note";
---

{
  references.length > 0 && (
    <nav
      class="flex flex-wrap items-center gap-2 text-sm"
      aria-label={`Backlinks for ${label} references`}
      data-pagefind-ignore
    >
      {references.map((reference) => (
        <a
          id={reference.backlinkId}
          href={`#${reference.id}`}
          class="text-muted-foreground hover:text-primary focus-visible:outline-ring inline-flex min-h-8 items-center rounded-sm underline underline-offset-4 focus-visible:outline-2 focus-visible:outline-offset-2"
          aria-label={`Back to ${label} reference ${reference.order}`}
        >
          <span aria-hidden="true">Back {reference.order}</span>
        </a>
      ))}
    </nav>
  )
}

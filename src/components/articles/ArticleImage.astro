---
import type { ImageMetadata } from "astro";

import {
  articleImagePresentation,
  type ArticleImageHeightPolicy,
} from "../../lib/article-image-policy";
import ArticleImageFrame from "./ArticleImageFrame.astro";
import ArticleImageInspectorScript from "./ArticleImageInspectorScript.astro";

interface Props {
  alt: string;
  caption?: string | undefined;
  heightPolicy?: ArticleImageHeightPolicy | undefined;
  src: ImageMetadata;
}

const { alt, caption, heightPolicy = "auto", src } = Astro.props;
const presentation = articleImagePresentation(heightPolicy);
const inspectLabel =
  alt.trim().length > 0 ? `View full image: ${alt}` : "View full image";
---

<figure
  class:list={[presentation.figureClass]}
  data-article-image-figure="true"
  data-article-image-inspectable={presentation.isInspectable ? "true" : "false"}
  data-article-image-policy={presentation.policy}
>
  <ArticleImageFrame
    src={src}
    alt={alt}
    frameClass={presentation.frameClass}
    imageClass={presentation.imageClass}
    inspectable={presentation.isInspectable}
    inspectionClass={presentation.inspectionClass}
    inspectLabel={inspectLabel}
    previewSizes={presentation.previewSizes}
  />
  {
    caption && (
      <figcaption class:list={[presentation.captionClass]}>
        {caption}
      </figcaption>
    )
  }
</figure>

{presentation.isInspectable && <ArticleImageInspectorScript />}

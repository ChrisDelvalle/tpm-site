---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
  alt: string;
  caption?: string | undefined;
  src: ImageMetadata;
}

const { alt, caption, src } = Astro.props;
---

<figure class="mx-auto grid gap-2">
  <Image
    src={src}
    alt={alt}
    layout="constrained"
    class="mx-auto block h-auto rounded-sm"
  />
  {
    caption && (
      <figcaption class="text-muted-foreground text-center text-sm">
        {caption}
      </figcaption>
    )
  }
</figure>

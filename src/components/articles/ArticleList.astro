---
import ArticleCard from "./ArticleCard.astro";
import type { ArticleListItem } from "../../lib/article-list";

interface Props {
  items: readonly ArticleListItem[];
  pagefindIgnore?: boolean;
}

const { items, pagefindIgnore = false } = Astro.props;
---

<ol
  class="grid min-w-0 gap-4"
  data-pagefind-ignore={pagefindIgnore ? true : undefined}
>
  {
    items.map((item) => (
      <li class="min-w-0">
        <ArticleCard
          author={item.author}
          authors={item.authors}
          category={item.category}
          date={item.date}
          description={item.description}
          href={item.href}
          title={item.title}
        />
      </li>
    ))
  }
</ol>

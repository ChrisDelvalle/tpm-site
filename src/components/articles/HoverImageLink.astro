---
import type { ImageMetadata } from "astro";

import HoverImageCard from "./HoverImageCard.astro";

/** Public props for inline article hover-image links. */
interface Props {
  alt?: string;
  expanded?: boolean;
  image: ImageMetadata;
  label: string;
}

const { image, label, alt = "", expanded = false } = Astro.props;
---

<HoverImageCard alt={alt} expanded={expanded} image={image} label={label} />

---
import type { ImageMetadata } from "astro";

import HoverImageCard from "./HoverImageCard";

/** Public props for inline article hover-image links. */
interface Props {
  alt?: string;
  expanded?: boolean;
  image: ImageMetadata;
  label: string;
}

const { image, label, alt = "", expanded = false } = Astro.props;
const hoverImage = {
  height: image.height,
  src: image.src,
  width: image.width,
};
---

<HoverImageCard
  client:idle
  alt={alt}
  expanded={expanded}
  image={hoverImage}
  label={label}
/>

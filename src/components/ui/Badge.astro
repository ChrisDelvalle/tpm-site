---
import type { HTMLAttributes } from "astro/types";

/** Public props for compact status, category, and metadata labels. */
interface Props extends HTMLAttributes<"span"> {
  size?: "sm" | "md";
  tone?: "muted" | "neutral" | "primary";
  variant?: "outline" | "soft" | "solid";
}

const {
  size = "md",
  tone = "neutral",
  variant = "soft",
  class: className,
  ...attrs
} = Astro.props;

const baseClasses =
  "inline-flex max-w-full items-center rounded-sm border font-medium tracking-normal";
const sizeClasses = {
  md: "px-2 py-1 text-sm",
  sm: "px-1.5 py-0.5 text-xs",
} as const;
const variantClasses = {
  muted: {
    outline: "border-border bg-transparent text-muted-foreground",
    soft: "border-transparent bg-muted text-muted-foreground",
    solid: "border-transparent bg-muted text-foreground",
  },
  neutral: {
    outline: "border-border bg-transparent text-foreground",
    soft: "border-transparent bg-card text-foreground",
    solid: "border-transparent bg-foreground text-background",
  },
  primary: {
    outline: "border-primary bg-transparent text-primary",
    soft: "border-transparent bg-primary/10 text-primary",
    solid: "border-transparent bg-primary text-primary-foreground",
  },
} as const;
---

<span
  {...attrs}
  class:list={[
    baseClasses,
    sizeClasses[size],
    variantClasses[tone][variant],
    className,
  ]}
>
  <slot />
</span>

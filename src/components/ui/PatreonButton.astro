---
import { Image } from "astro:assets";
import type { HTMLAttributes } from "astro/types";

import patreonLockupWhite from "./assets/patreon-lockup-white.svg";

/** Public props for the Patreon-branded support link. */
interface Props extends HTMLAttributes<"a"> {
  href: string;
}

const {
  href,
  target,
  rel,
  class: className,
  "aria-label": ariaLabel = "Support Us",
  ...attrs
} = Astro.props;

const safeRel = target === "_blank" && rel === undefined ? "noreferrer" : rel;
---

<a
  {...attrs}
  href={href}
  target={target}
  rel={safeRel}
  aria-label={ariaLabel}
  class:list={[
    "focus-visible:outline-ring inline-flex h-9 w-32 min-w-0 shrink items-center justify-center rounded-xl border border-transparent bg-[#F96854] px-2 py-1.5 no-underline transition-colors hover:bg-[#E05240] focus-visible:outline-2 focus-visible:outline-offset-2",
    className,
  ]}
>
  <Image
    src={patreonLockupWhite}
    alt=""
    layout="fixed"
    loading="eager"
    class="h-4 w-auto max-w-full"
  />
</a>

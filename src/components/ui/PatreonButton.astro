---
import type { HTMLAttributes } from "astro/types";

import BrandButton from "./BrandButton.astro";
import patreonLockupWhite from "./assets/patreon-lockup-white.svg";

/** Public props for the Patreon-branded support link. */
interface Props extends HTMLAttributes<"a"> {
  href: string;
}

const {
  href,
  target,
  rel,
  class: className,
  "aria-label": ariaLabel = "Support Us",
  ...attrs
} = Astro.props;
---

<BrandButton
  {...attrs}
  href={href}
  target={target}
  rel={rel}
  aria-label={ariaLabel}
  label="Support Us"
  logo={patreonLockupWhite}
  backgroundClass="bg-[#F96854]"
  hoverBackgroundClass="hover:bg-[#E05240]"
  class:list={[className]}
/>

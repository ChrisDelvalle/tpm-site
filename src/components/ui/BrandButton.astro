---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import type { HTMLAttributes } from "astro/types";

/** Public props for branded external CTA buttons. */
interface Props extends HTMLAttributes<"a"> {
  backgroundClass: string;
  hoverBackgroundClass: string;
  href: string;
  label: string;
  logo: ImageMetadata;
  logoClass?: string | undefined;
}

const {
  backgroundClass,
  hoverBackgroundClass,
  href,
  label,
  logo,
  logoClass = "h-4 w-auto max-w-full",
  target,
  rel,
  class: className,
  "aria-label": ariaLabel = label,
  ...attrs
} = Astro.props;

const safeRel = target === "_blank" && rel === undefined ? "noreferrer" : rel;
---

<a
  {...attrs}
  href={href}
  target={target}
  rel={safeRel}
  aria-label={ariaLabel}
  class:list={[
    "focus-visible:outline-ring inline-flex h-9 w-32 min-w-0 shrink items-center justify-center rounded-xl border border-transparent px-2 py-1.5 no-underline transition-colors focus-visible:outline-2 focus-visible:outline-offset-2",
    backgroundClass,
    hoverBackgroundClass,
    className,
  ]}
>
  <Image
    src={logo}
    alt=""
    layout="fixed"
    loading="eager"
    class:list={[logoClass]}
  />
</a>

---
import type { HTMLAttributes } from "astro/types";

import {
  buttonLinkBaseClasses,
  buttonSizeClasses,
  buttonVariantClasses,
  prefetchAttributeValue,
  type ButtonSize,
  type ButtonTone,
  type ButtonVariant,
  type PrefetchValue,
} from "./button-variants";

/** Public props for links styled as call-to-action buttons. */
interface Props extends HTMLAttributes<"a"> {
  href: string;
  prefetch?: PrefetchValue;
  size?: ButtonSize;
  tone?: ButtonTone;
  variant?: ButtonVariant;
}

const {
  href,
  prefetch,
  variant = "solid",
  size = "md",
  tone = "primary",
  target,
  rel,
  class: className,
  ...attrs
} = Astro.props;

const safeRel = target === "_blank" && rel === undefined ? "noreferrer" : rel;
const prefetchAttribute = prefetchAttributeValue(prefetch);
---

<a
  {...attrs}
  href={href}
  target={target}
  rel={safeRel}
  data-astro-prefetch={prefetchAttribute}
  class:list={[
    buttonLinkBaseClasses,
    buttonSizeClasses[size],
    buttonVariantClasses[tone][variant],
    className,
  ]}
>
  <slot />
</a>

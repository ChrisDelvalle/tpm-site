---
import type { HTMLAttributes } from "astro/types";
import { ChevronLeft, ChevronRight } from "lucide-astro";

import IconButton from "./IconButton.astro";

interface Props extends HTMLAttributes<"div"> {
  listClass?: HTMLAttributes<"ul">["class"];
  nextLabel: string;
  previousLabel: string;
  railId: string;
  viewportClass?: HTMLAttributes<"div">["class"];
}

const {
  listClass,
  nextLabel,
  previousLabel,
  railId,
  viewportClass,
  class: className,
  ...attrs
} = Astro.props;
---

<div {...attrs} class:list={["relative min-w-0", className]} data-scroll-rail>
  <div
    class="from-background via-background/90 pointer-events-none absolute inset-y-0 start-0 z-10 hidden items-center bg-linear-to-r to-transparent ps-1 pe-8"
    data-scroll-rail-controls
    data-scroll-rail-start
    hidden
  >
    <IconButton
      aria-controls={railId}
      data-scroll-rail-previous
      disabled
      label={previousLabel}
      size="sm"
      variant="outline"
      class="bg-background/95 pointer-events-auto shadow-sm"
    >
      <ChevronLeft class="size-4" aria-hidden="true" />
    </IconButton>
  </div>
  <div
    id={railId}
    class:list={[
      "min-w-0 snap-x snap-mandatory [scrollbar-width:thin] overflow-x-auto overscroll-x-contain pb-2",
      viewportClass,
    ]}
    data-scroll-rail-viewport
  >
    <ul
      class:list={[
        "grid w-max min-w-full auto-cols-fr grid-flow-col gap-3",
        listClass,
      ]}
      data-scroll-rail-list
    >
      <slot />
    </ul>
  </div>
  <div
    class="from-background via-background/90 pointer-events-none absolute inset-y-0 end-0 z-10 hidden items-center bg-linear-to-l to-transparent ps-8 pe-1"
    data-scroll-rail-controls
    data-scroll-rail-end
    hidden
  >
    <IconButton
      aria-controls={railId}
      data-scroll-rail-next
      disabled
      label={nextLabel}
      size="sm"
      variant="outline"
      class="bg-background/95 pointer-events-auto shadow-sm"
    >
      <ChevronRight class="size-4" aria-hidden="true" />
    </IconButton>
  </div>
</div>

<script src="../../scripts/horizontal-scroll-rail.ts"></script>

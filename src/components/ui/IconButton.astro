---
import type { HTMLAttributes } from "astro/types";

/** Public props for icon-only button actions. */
interface Props extends HTMLAttributes<"button"> {
  label: string;
  pressed?: boolean;
  size?: "sm" | "md" | "lg";
  tone?: "danger" | "neutral" | "primary";
  variant?: "ghost" | "outline" | "solid";
}

const {
  label,
  variant = "ghost",
  size = "md",
  tone = "neutral",
  pressed,
  disabled = false,
  type = "button",
  title,
  class: className,
  ...attrs
} = Astro.props;

const baseClasses =
  "inline-flex shrink-0 items-center justify-center rounded-sm border transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring disabled:pointer-events-none disabled:cursor-not-allowed disabled:opacity-60";
const sizeClasses = {
  lg: "size-11",
  md: "size-9",
  sm: "size-8",
} as const;
const variantClasses = {
  danger: {
    ghost:
      "border-transparent bg-transparent text-destructive hover:bg-destructive/10",
    outline:
      "border-destructive bg-transparent text-destructive hover:bg-destructive/10",
    solid:
      "border-transparent bg-destructive text-destructive-foreground hover:bg-destructive/90",
  },
  neutral: {
    ghost:
      "border-transparent bg-transparent text-muted-foreground hover:bg-muted hover:text-foreground",
    outline: "border-border bg-transparent text-foreground hover:bg-muted",
    solid:
      "border-transparent bg-foreground text-background hover:bg-foreground/90",
  },
  primary: {
    ghost: "border-transparent bg-transparent text-primary hover:bg-primary/10",
    outline: "border-primary bg-transparent text-primary hover:bg-primary/10",
    solid:
      "border-transparent bg-primary text-primary-foreground hover:bg-primary/90",
  },
} as const;
---

<button
  {...attrs}
  type={type}
  disabled={disabled}
  aria-label={label}
  aria-pressed={pressed}
  title={title ?? label}
  class:list={[
    baseClasses,
    sizeClasses[size],
    variantClasses[tone][variant],
    className,
  ]}
>
  <slot />
</button>

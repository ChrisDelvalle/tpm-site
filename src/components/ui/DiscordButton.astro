---
import type { HTMLAttributes } from "astro/types";

import BrandButton from "./BrandButton.astro";
import discordLogoWhite from "./assets/discord-logo-white.svg";

/** Public props for the Discord-branded call-to-action link. */
interface Props extends HTMLAttributes<"a"> {
  href: string;
}

const {
  href,
  target,
  rel,
  class: className,
  "aria-label": ariaLabel = "Join Discord",
  ...attrs
} = Astro.props;
---

<BrandButton
  {...attrs}
  href={href}
  target={target}
  rel={rel}
  aria-label={ariaLabel}
  label="Join Discord"
  logo={discordLogoWhite}
  backgroundClass="bg-[#5865F2]"
  hoverBackgroundClass="hover:bg-[#4752C4]"
  class:list={[className]}
/>

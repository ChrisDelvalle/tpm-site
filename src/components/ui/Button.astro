---
import type { HTMLAttributes } from "astro/types";

import {
  buttonControlBaseClasses,
  buttonSizeClasses,
  buttonVariantClasses,
  type ButtonSize,
  type ButtonTone,
  type ButtonVariant,
} from "./button-variants";

/** Public props for native button actions. */
interface Props extends HTMLAttributes<"button"> {
  pressed?: boolean;
  size?: ButtonSize;
  tone?: ButtonTone;
  variant?: ButtonVariant;
}

const {
  variant = "solid",
  size = "md",
  tone = "primary",
  pressed,
  disabled = false,
  type = "button",
  class: className,
  ...attrs
} = Astro.props;
---

<button
  {...attrs}
  type={type}
  disabled={disabled}
  aria-pressed={pressed}
  class:list={[
    buttonControlBaseClasses,
    buttonSizeClasses[size],
    buttonVariantClasses[tone][variant],
    className,
  ]}
>
  <slot />
</button>

---
import AuthorLink from "./AuthorLink.astro";
import type { AuthorSummary } from "../../lib/authors";

interface Props {
  authors?: readonly AuthorSummary[] | undefined;
  legacyAuthor?: string | undefined;
  mode?: "inline" | "stacked";
}

const { authors = [], legacyAuthor, mode = "inline" } = Astro.props;
const hasStructuredAuthors = authors.length > 0;
const separatorClass = mode === "stacked" ? "hidden" : "text-muted-foreground";
---

{
  hasStructuredAuthors ? (
    <span
      class:list={[
        mode === "stacked" ? "grid gap-1" : "inline-flex flex-wrap gap-x-1",
      ]}
      data-author-byline
    >
      {authors.map((author, index) => (
        <Fragment>
          <AuthorLink author={author} />
          {index < authors.length - 1 && (
            <span class:list={separatorClass}>&</span>
          )}
        </Fragment>
      ))}
    </span>
  ) : (
    legacyAuthor && <span data-author-byline>{legacyAuthor}</span>
  )
}

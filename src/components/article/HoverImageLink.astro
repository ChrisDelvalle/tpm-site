---
import type { ImageMetadata } from "astro";

import HoverImageCard from "./HoverImageCard";

interface Props {
  image: ImageMetadata;
  label: string;
  alt?: string;
  expanded?: boolean;
}

const { image, label, alt = "", expanded = false } = Astro.props;
const hoverImage = {
  src: image.src,
  width: image.width,
  height: image.height,
};
---

<HoverImageCard
  client:idle
  image={hoverImage}
  label={label}
  alt={alt}
  expanded={expanded}
/>

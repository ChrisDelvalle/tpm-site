---
import type { ImageMetadata } from "astro";

import HoverImageLink from "../articles/HoverImageLink.astro";

/** Compatibility props for the legacy hover-image link import path. */
interface Props {
  alt?: string;
  expanded?: boolean;
  image: ImageMetadata;
  label: string;
}

const props = Astro.props;
---

<HoverImageLink {...props} />

---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  image: ImageMetadata;
  label: string;
  alt?: string;
  expanded?: boolean;
}

const { image, label, alt = "", expanded = false } = Astro.props;
const className = expanded ? "hoverexpanded" : "hover";
const maxWidthRem = expanded ? 40 : 30;
const maxHeightRem = expanded ? 34 : 28;
const aspectRatio = image.width / image.height;
const displayWidthRem = Math.min(maxWidthRem, maxHeightRem * aspectRatio);
const previewStyle = `width: min(${displayWidthRem.toFixed(3)}rem, calc(100vw - 2rem)); max-width: none; max-height: calc(100svh - 2rem); height: auto;`;
---

<a class:list={[className, "group relative inline-block"]} href={image.src}>
  <Image
    class:list={[
      "pointer-events-none invisible absolute bottom-[calc(100%+0.5rem)] left-1/2 z-20 -translate-x-1/2 translate-y-1 rounded-lg border border-[var(--line)] bg-[var(--bg)] p-1 opacity-0 shadow-[var(--shadow-sm)] transition-[opacity,transform,visibility] duration-150 ease-in-out group-hover:visible group-hover:translate-y-0 group-hover:opacity-100 group-focus-visible:visible group-focus-visible:translate-y-0 group-focus-visible:opacity-100 motion-reduce:transition-none",
    ]}
    style={previewStyle}
    src={image}
    alt={alt}
  />
  {label}
</a>

---
import type { ImageMetadata } from "astro";

import HoverImageCard from "../articles/HoverImageCard.astro";

/** Compatibility props for the legacy hover-image card import path. */
interface Props {
  alt?: string;
  expanded?: boolean;
  image: ImageMetadata;
  label: string;
}

const props = Astro.props;
---

<HoverImageCard {...props} />

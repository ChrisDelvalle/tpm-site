---
import type { ImageMetadata } from "astro";

import HoverImageParagraph from "../articles/HoverImageParagraph.astro";

/** Compatibility props for the legacy hover-image paragraph import path. */
interface Props {
  after: string;
  alt?: string;
  expanded?: boolean;
  image: ImageMetadata;
  label: string;
}

const props = Astro.props;
---

<HoverImageParagraph {...props} />

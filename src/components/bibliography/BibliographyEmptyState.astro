---
import TextLink from "../ui/TextLink.astro";

interface Props {
  auditHref?: string;
}

const { auditHref = "/articles/" } = Astro.props;
---

<section class="border-border bg-muted/30 grid gap-3 rounded-sm border p-5">
  <h2 class="text-foreground text-xl font-semibold">
    No bibliography entries yet
  </h2>
  <p class="text-muted-foreground max-w-3xl">
    Published articles do not yet contain canonical BibTeX-backed citations.
    Ordinary article links are intentionally not listed here.
  </p>
  <p class="text-muted-foreground max-w-3xl text-sm">
    Browse the <TextLink href={auditHref} prefetch="hover"
      >article archive</TextLink
    >
    while sources are being prepared for this index.
  </p>
</section>

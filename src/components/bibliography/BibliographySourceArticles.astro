---
import type { BibliographySourceArticle } from "../../lib/bibliography";
import TextLink from "../ui/TextLink.astro";

interface Props {
  articles: readonly BibliographySourceArticle[];
}

const { articles } = Astro.props;
---

{
  articles.length > 0 && (
    <section class="grid gap-2" aria-label="Articles citing this source">
      <h3 class="text-muted-foreground text-sm font-semibold">
        Cited by {articles.length === 1 ? "article" : "articles"}
      </h3>
      <ul class="grid gap-1 text-sm">
        {articles.map((article) => (
          <li class="text-muted-foreground flex flex-wrap gap-x-2 gap-y-1">
            <TextLink href={article.href} prefetch="hover">
              {article.title}
            </TextLink>
            {article.date !== "" && <span>{article.date}</span>}
          </li>
        ))}
      </ul>
    </section>
  )
}

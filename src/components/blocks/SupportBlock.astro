---
import type { HTMLAttributes } from "astro/types";

import DiscordButton from "../ui/DiscordButton.astro";
import PatreonButton from "../ui/PatreonButton.astro";
import { siteConfig } from "../../lib/site-config";

interface Props extends HTMLAttributes<"section"> {
  body?: string;
  discordHref?: string;
  headingId?: string;
  patreonHref?: string;
  title?: string;
}

const {
  body = siteConfig.support.block.body,
  discordHref = siteConfig.support.discord.href,
  headingId = "support-block-heading",
  patreonHref = siteConfig.support.patreon.href,
  title = siteConfig.support.block.title,
  class: className,
  ...attrs
} = Astro.props;
---

<section
  {...attrs}
  data-support-block
  class:list={[
    "border-border bg-muted/40 grid w-full min-w-0 gap-4 rounded-sm border p-5",
    className,
  ]}
  aria-labelledby={headingId}
>
  <div class="grid min-w-0 gap-1">
    <h2
      id={headingId}
      class="text-foreground m-0 min-w-0 text-xl font-semibold tracking-normal break-words"
    >
      {title}
    </h2>
    <p class="text-muted-foreground min-w-0 text-sm break-words">{body}</p>
  </div>
  <div class="flex min-w-0 flex-wrap items-center gap-3">
    <PatreonButton
      href={patreonHref}
      aria-label={siteConfig.support.patreon.ariaLabel}
    />
    <DiscordButton
      href={discordHref}
      aria-label={siteConfig.support.discord.ariaLabel}
    />
  </div>
</section>

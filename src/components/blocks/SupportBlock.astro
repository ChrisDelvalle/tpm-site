---
import type { HTMLAttributes } from "astro/types";

import LinkButton from "../ui/LinkButton.astro";

interface Props extends HTMLAttributes<"section"> {
  body?: string;
  headingId?: string;
  href?: string;
  label?: string;
  title?: string;
}

const {
  body = "Help keep independent research and writing going.",
  headingId = "support-block-heading",
  href = "https://patreon.com/thephilosophersmeme",
  label = "Support Us",
  title = "Support The Philosopher's Meme",
  class: className,
  ...attrs
} = Astro.props;
---

<section
  {...attrs}
  data-support-block
  class:list={[
    "border-border bg-muted/40 grid w-full min-w-0 gap-4 rounded-sm border p-5",
    className,
  ]}
  aria-labelledby={headingId}
>
  <div class="grid min-w-0 gap-1">
    <h2
      id={headingId}
      class="text-foreground m-0 min-w-0 text-xl font-semibold tracking-normal break-words"
    >
      {title}
    </h2>
    <p class="text-muted-foreground min-w-0 text-sm break-words">{body}</p>
  </div>
  <div>
    <LinkButton href={href}>{label}</LinkButton>
  </div>
</section>

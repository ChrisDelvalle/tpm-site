---
import TextLink from "../ui/TextLink.astro";

interface DiscoveryLink {
  href: string;
  label: string;
}

interface Props {
  links: readonly DiscoveryLink[];
  title?: string;
}

const { links, title = "Read" } = Astro.props;
const prefetchAttrsFor = (href: string) =>
  href.startsWith("/") ? { prefetch: "hover" as const } : {};
---

<nav
  class="text-muted-foreground flex w-fit max-w-full min-w-0 flex-nowrap items-center gap-x-2 overflow-hidden py-0 text-xs sm:gap-x-3 sm:text-sm"
  aria-label="Homepage reading navigation"
  data-home-discovery-links
>
  <span class="text-foreground shrink-0 font-semibold whitespace-nowrap">
    {title}
  </span>
  <span aria-hidden="true">/</span>
  <ul class="flex min-w-0 flex-nowrap gap-x-2 overflow-hidden sm:gap-x-3">
    {
      links.map((link) => (
        <li class="min-w-0 shrink">
          <TextLink
            href={link.href}
            variant="subtle"
            tone="muted"
            class="block truncate whitespace-nowrap"
            {...prefetchAttrsFor(link.href)}
          >
            {link.label}
          </TextLink>
        </li>
      ))
    }
  </ul>
</nav>

---
import type { ImageMetadata } from "astro";

import HomeCurrentPanel from "./HomeCurrentPanel.astro";
import HomeHeroBlock from "./HomeHeroBlock.astro";
import HomeStartHerePanel from "./HomeStartHerePanel.astro";
import type { ArticleListItem } from "../../lib/article-list";

interface HomeCurrentLink {
  description?: string | undefined;
  href: string;
  label: string;
}

interface Props {
  currentLinks: readonly HomeCurrentLink[];
  darkImage: ImageMetadata;
  imageAlt: string;
  lightImage: ImageMetadata;
  startHereItems: readonly ArticleListItem[];
  tagline: string;
}

const {
  currentLinks,
  darkImage,
  imageAlt,
  lightImage,
  startHereItems,
  tagline,
} = Astro.props;
---

<div
  class="grid min-w-0 gap-4 lg:grid-cols-[minmax(0,1fr)_minmax(20rem,1.35fr)_minmax(0,1fr)] lg:items-stretch"
  data-home-masthead
>
  <HomeStartHerePanel items={startHereItems} />
  <HomeHeroBlock
    lightImage={lightImage}
    darkImage={darkImage}
    imageAlt={imageAlt}
    tagline={tagline}
  />
  <HomeCurrentPanel links={currentLinks} />
</div>

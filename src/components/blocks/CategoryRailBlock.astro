---
import type { HTMLAttributes } from "astro/types";

import TermRailCard from "./TermRailCard.astro";
import ScrollRail from "../ui/ScrollRail.astro";
import type { SectionNavItem } from "../../lib/navigation";

interface Props extends HTMLAttributes<"section"> {
  emptyText?: string;
  items: readonly SectionNavItem[];
  railId?: string;
  title?: string;
}

const {
  emptyText = "No categories are available yet.",
  items,
  railId = "category-rail",
  title = "Categories",
  class: className,
  "aria-label": ariaLabel,
  ...attrs
} = Astro.props;
const sectionLabel = ariaLabel ?? title;
---

<section
  {...attrs}
  class:list={["grid min-w-0 gap-4", className]}
  aria-label={sectionLabel}
  data-category-rail
>
  {
    items.length > 0 ? (
      <ScrollRail
        railId={railId}
        previousLabel="Scroll categories left"
        nextLabel="Scroll categories right"
      >
        {items.map((item) => (
          <TermRailCard
            count={item.articles.length}
            description={item.description}
            href={item.href}
            title={item.title}
          />
        ))}
      </ScrollRail>
    ) : (
      <p class="text-muted-foreground text-sm" data-category-rail-empty>
        {emptyText}
      </p>
    )
  }
</section>

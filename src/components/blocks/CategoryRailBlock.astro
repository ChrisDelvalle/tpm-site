---
import type { HTMLAttributes } from "astro/types";

import TermRailBlock from "./TermRailBlock.astro";
import type { SectionNavItem } from "../../lib/navigation";

interface Props extends HTMLAttributes<"section"> {
  emptyText?: string;
  items: readonly SectionNavItem[];
  railId?: string;
  title?: string;
}

const {
  emptyText = "No categories are available yet.",
  items,
  railId = "category-rail",
  title = "Categories",
  class: className,
  "aria-label": ariaLabel,
  ...attrs
} = Astro.props;
const sectionLabel = ariaLabel ?? title;
const termItems = items.map((item) => ({
  count: item.articles.length,
  description: item.description,
  href: item.href,
  title: item.title,
}));
---

<TermRailBlock
  {...attrs}
  aria-label={sectionLabel}
  class:list={[className]}
  data-category-rail
  data-category-rail-empty={items.length === 0 ? true : undefined}
  emptyText={emptyText}
  items={termItems}
  nextLabel="Scroll categories right"
  previousLabel="Scroll categories left"
  railId={railId}
  title={title}
/>

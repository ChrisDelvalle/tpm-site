---
import ArticleList from "../articles/ArticleList.astro";
import type { ArticleListItem } from "../../lib/article-list";

interface Props {
  items: readonly ArticleListItem[];
  title?: string;
}

const { items, title = "Start Here" } = Astro.props;
---

<section class="grid max-w-3xl gap-4" aria-labelledby="home-featured-heading">
  <h2
    id="home-featured-heading"
    class="text-foreground m-0 text-2xl font-semibold tracking-normal"
  >
    {title}
  </h2>
  {
    items.length > 0 ? (
      <ArticleList items={items} />
    ) : (
      <p class="text-muted-foreground">Featured articles will appear here.</p>
    )
  }
</section>

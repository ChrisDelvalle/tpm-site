---
import type { ImageMetadata } from "astro";

import ThemedImage from "../media/ThemedImage.astro";
import LinkButton from "../ui/LinkButton.astro";

interface Props {
  darkImage: ImageMetadata;
  imageAlt: string;
  lightImage: ImageMetadata;
  tagline: string;
}

const { darkImage, imageAlt, lightImage, tagline } = Astro.props;
---

<section class="grid gap-6" aria-labelledby="home-hero-heading">
  <h1 id="home-hero-heading" class="sr-only">The Philosopher's Meme</h1>
  <ThemedImage
    lightImage={lightImage}
    darkImage={darkImage}
    alt={imageAlt}
    layout="full-width"
    loading="eager"
    fetchpriority="high"
    class="block h-auto w-full"
  />
  <p class="text-muted-foreground max-w-2xl text-lg leading-8">{tagline}</p>
  <div class="flex flex-wrap gap-3">
    <LinkButton href="https://patreon.com/thephilosophersmeme">
      Support Us
    </LinkButton>
    <LinkButton
      href="https://discord.gg/8MVFRMa"
      variant="outline"
      tone="neutral"
    >
      Join TPM Discord
    </LinkButton>
  </div>
</section>

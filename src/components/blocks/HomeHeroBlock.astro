---
import type { ImageMetadata } from "astro";

import ThemedImage from "../media/ThemedImage.astro";
import DiscordButton from "../ui/DiscordButton.astro";
import PatreonButton from "../ui/PatreonButton.astro";
import { siteConfig } from "../../lib/site-config";

interface Props {
  darkImage: ImageMetadata;
  imageAlt: string;
  lightImage: ImageMetadata;
  tagline?: string | undefined;
}

const { darkImage, imageAlt, lightImage, tagline } = Astro.props;
---

<section
  class="grid min-w-0 content-center justify-items-center gap-4 text-center"
  aria-labelledby="home-hero-heading"
  data-home-hero-block
>
  <h1 id="home-hero-heading" class="sr-only">{siteConfig.identity.title}</h1>
  <ThemedImage
    lightImage={lightImage}
    darkImage={darkImage}
    alt={imageAlt}
    layout="full-width"
    loading="eager"
    fetchpriority="high"
    sizes="(min-width: 80rem) 48rem, (min-width: 64rem) 64vw, calc(100vw - 2rem)"
    class="mx-auto h-auto w-full max-w-3xl object-contain"
  />
  {
    tagline && (
      <p class="text-muted-foreground max-w-xl text-base leading-7">
        {tagline}
      </p>
    )
  }
  {
    siteConfig.features.support && (
      <div
        class="flex w-full max-w-[17rem] min-w-0 flex-nowrap justify-center gap-3"
        data-home-hero-cta-row
      >
        <PatreonButton
          href={siteConfig.support.patreon.href}
          aria-label={siteConfig.support.patreon.label}
        />
        <DiscordButton
          href={siteConfig.support.discord.href}
          aria-label={siteConfig.support.discord.label}
        />
      </div>
    )
  }
</section>

---
import CategoryRailBlock from "./CategoryRailBlock.astro";
import type { SectionNavItem } from "../../lib/navigation";

interface Props {
  emptyText?: string;
  items: readonly SectionNavItem[];
  title?: string;
}

const {
  emptyText = "No categories are available yet.",
  items,
  title = "Categories",
} = Astro.props;
---

<CategoryRailBlock
  data-home-category-overview
  emptyText={emptyText}
  items={items}
  railId="home-categories-rail"
  title={title}
/>

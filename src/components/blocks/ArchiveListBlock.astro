---
import ArticleList from "../articles/ArticleList.astro";
import SectionHeader from "../ui/SectionHeader.astro";
import type { ArticleListItem } from "../../lib/article-list";
import { htmlIdFromText } from "../../lib/html";

interface Props {
  description?: string | undefined;
  eyebrow?: string | undefined;
  headingLevel?: 1 | 2;
  items: readonly ArticleListItem[];
  pagefindIgnore?: boolean;
  title: string;
}

const {
  description,
  eyebrow,
  headingLevel = 1,
  items,
  pagefindIgnore = false,
  title,
} = Astro.props;
const headingId = `${htmlIdFromText(title, "archive")}-heading`;
---

<section class="grid gap-6" aria-labelledby={headingId}>
  <SectionHeader
    description={description}
    eyebrow={eyebrow}
    headingId={headingId}
    headingLevel={headingLevel}
    layout="stacked"
    size={headingLevel === 1 ? "page" : "section"}
    title={title}
  />
  <ArticleList items={items} pagefindIgnore={pagefindIgnore} />
</section>

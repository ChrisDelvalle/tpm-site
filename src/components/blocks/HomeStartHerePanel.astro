---
import CompactEntryPanel from "./CompactEntryPanel.astro";
import type { ArticleListItem } from "../../lib/article-list";

interface Props {
  description?: string;
  items: readonly ArticleListItem[];
  title?: string;
}

const {
  description = "Start with these curated entry points into the site's core article threads.",
  items,
  title = "Start Here",
} = Astro.props;
---

<CompactEntryPanel
  description={description}
  emptyText="Curated starter articles will appear here."
  headingId="home-start-here-heading"
  items={items}
  title={title}
  data-home-start-here-panel
/>

---
import LinkButton from "../ui/LinkButton.astro";
import TextLink from "../ui/TextLink.astro";

interface Props {
  title?: string;
}

const { title = "Explore the Archive" } = Astro.props;
---

<section class="grid max-w-3xl gap-3" aria-labelledby="home-archive-heading">
  <h2
    id="home-archive-heading"
    class="text-foreground m-0 text-2xl font-semibold tracking-normal"
  >
    {title}
  </h2>
  <p class="text-muted-foreground">
    Browse the full <TextLink href="/articles/">article archive</TextLink>,
    explore <TextLink href="/categories/">categories</TextLink>, or subscribe to
    the <TextLink href="/feed.xml">RSS feed</TextLink>.
  </p>
  <div class="flex flex-wrap gap-3">
    <LinkButton href="/articles/" variant="outline" tone="neutral">
      Articles
    </LinkButton>
    <LinkButton href="/categories/" variant="outline" tone="neutral">
      Categories
    </LinkButton>
  </div>
</section>

---
import LinkButton from "../ui/LinkButton.astro";
import TextLink from "../ui/TextLink.astro";
import {
  articlesIndexUrl,
  categoriesIndexUrl,
  feedUrl,
} from "../../lib/routes";

interface Props {
  title?: string;
}

const { title = "Explore the Archive" } = Astro.props;
---

<section class="grid max-w-3xl gap-3" aria-labelledby="home-archive-heading">
  <h2
    id="home-archive-heading"
    class="text-foreground m-0 text-2xl font-semibold tracking-normal"
  >
    {title}
  </h2>
  <p class="text-muted-foreground">
    Browse the full <TextLink href={articlesIndexUrl()}
      >article archive</TextLink
    >, explore <TextLink href={categoriesIndexUrl()}>categories</TextLink>, or
    subscribe to the <TextLink href={feedUrl()}>RSS feed</TextLink>.
  </p>
  <div class="flex flex-wrap gap-3">
    <LinkButton href={articlesIndexUrl()} variant="outline" tone="neutral">
      Articles
    </LinkButton>
    <LinkButton href={categoriesIndexUrl()} variant="outline" tone="neutral">
      Categories
    </LinkButton>
  </div>
</section>

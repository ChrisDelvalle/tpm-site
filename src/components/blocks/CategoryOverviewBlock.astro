---
import TermOverviewBlock from "./TermOverviewBlock.astro";
import type { SectionNavItem } from "../../lib/navigation";

interface Props {
  columns?: "compact" | "default";
  description?: string | undefined;
  headingLevel?: 1 | 2;
  headingId?: string;
  items: readonly SectionNavItem[];
  title?: string;
}

const {
  columns = "default",
  description,
  headingLevel = 1,
  headingId = "category-overview-heading",
  items,
  title = "Categories",
} = Astro.props;
const terms = items.map((item) => ({
  count: item.articles.length,
  description: item.description,
  href: item.href,
  title: item.title,
}));
---

<TermOverviewBlock
  columns={columns}
  description={description}
  headingId={headingId}
  headingLevel={headingLevel}
  items={terms}
  title={title}
/>

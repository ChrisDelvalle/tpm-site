---
import TermCard from "./TermCard.astro";
import SectionHeader from "../ui/SectionHeader.astro";

interface TermOverviewItem {
  count: number;
  description?: string | undefined;
  href: string;
  title: string;
}

interface Props {
  columns?: "compact" | "default";
  description?: string | undefined;
  emptyLabel?: string;
  headingLevel?: 1 | 2;
  headingId?: string;
  itemNoun?: string;
  itemNounPlural?: string;
  items: readonly TermOverviewItem[];
  title: string;
}

const {
  columns = "default",
  description,
  emptyLabel = "No terms are available yet.",
  headingLevel = 1,
  headingId = "term-overview-heading",
  itemNoun = "article",
  itemNounPlural = `${itemNoun}s`,
  items,
  title,
} = Astro.props;
const columnClasses = {
  compact: "sm:grid-cols-2",
  default: "sm:grid-cols-2 xl:grid-cols-4",
} as const;
---

<section class="grid gap-4" aria-labelledby={headingId}>
  <SectionHeader
    description={description}
    headingId={headingId}
    headingLevel={headingLevel}
    layout="stacked"
    size={headingLevel === 1 ? "page" : "section"}
    title={title}
  />
  {
    items.length > 0 ? (
      <ul class:list={["grid gap-3", columnClasses[columns]]}>
        {items.map((item) => (
          <TermCard
            count={item.count}
            description={item.description}
            href={item.href}
            itemNoun={itemNoun}
            itemNounPlural={itemNounPlural}
            title={item.title}
          />
        ))}
      </ul>
    ) : (
      <p class="text-muted-foreground text-sm" data-term-overview-empty>
        {emptyLabel}
      </p>
    )
  }
</section>

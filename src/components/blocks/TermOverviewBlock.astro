---
import TextLink from "../ui/TextLink.astro";

interface TermOverviewItem {
  count: number;
  description?: string | undefined;
  href: string;
  title: string;
}

interface Props {
  columns?: "compact" | "default";
  description?: string | undefined;
  emptyLabel?: string;
  headingLevel?: 1 | 2;
  headingId?: string;
  items: readonly TermOverviewItem[];
  title: string;
}

const {
  columns = "default",
  description,
  emptyLabel = "No terms are available yet.",
  headingLevel = 1,
  headingId = "term-overview-heading",
  items,
  title,
} = Astro.props;
const columnClasses = {
  compact: "sm:grid-cols-2",
  default: "sm:grid-cols-2 xl:grid-cols-4",
} as const;
---

<section class="grid gap-4" aria-labelledby={headingId}>
  <header class="grid gap-2">
    {
      headingLevel === 1 ? (
        <h1
          id={headingId}
          class="text-foreground m-0 text-4xl font-bold tracking-normal"
        >
          {title}
        </h1>
      ) : (
        <h2
          id={headingId}
          class="text-foreground m-0 text-2xl font-semibold tracking-normal"
        >
          {title}
        </h2>
      )
    }
    {
      description && (
        <p class="text-muted-foreground max-w-3xl text-lg">{description}</p>
      )
    }
  </header>
  {
    items.length > 0 ? (
      <ul class:list={["grid gap-3", columnClasses[columns]]}>
        {items.map((item) => (
          <li class="border-border bg-card grid gap-1 rounded-sm border p-4">
            <TextLink
              href={item.href}
              tone="neutral"
              class="font-semibold"
              prefetch="hover"
            >
              {item.title}
            </TextLink>
            {item.description && (
              <p class="text-muted-foreground text-sm">{item.description}</p>
            )}
            <p class="text-muted-foreground text-xs">
              {item.count} {item.count === 1 ? "article" : "articles"}
            </p>
          </li>
        ))}
      </ul>
    ) : (
      <p class="text-muted-foreground text-sm" data-term-overview-empty>
        {emptyLabel}
      </p>
    )
  }
</section>

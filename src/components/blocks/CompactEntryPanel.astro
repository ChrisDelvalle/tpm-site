---
import type { HTMLAttributes } from "astro/types";

import CompactEntryList from "../articles/CompactEntryList.astro";
import type { CompactEntryItem } from "../articles/compact-entry";
import TextLink from "../ui/TextLink.astro";

interface Props extends HTMLAttributes<"section"> {
  description?: string | undefined;
  emptyText?: string;
  headingId: string;
  items: readonly CompactEntryItem[];
  ordered?: boolean;
  showDescription?: boolean;
  title: string;
  titleHref?: string | undefined;
}

const {
  description,
  emptyText,
  headingId,
  items,
  ordered = true,
  showDescription = false,
  title,
  titleHref,
  class: className,
  ...attrs
} = Astro.props;
---

<section
  {...attrs}
  class:list={[
    "border-border bg-muted/30 grid min-w-0 content-start gap-4 rounded-sm border p-4",
    className,
  ]}
  aria-labelledby={headingId}
  data-compact-entry-panel
>
  <div class="grid gap-1">
    <h2
      id={headingId}
      class="text-foreground m-0 text-lg font-semibold tracking-normal"
    >
      {
        titleHref === undefined ? (
          title
        ) : (
          <TextLink
            href={titleHref}
            tone="neutral"
            variant="nav"
            prefetch="hover"
            class="font-semibold"
          >
            {title}
          </TextLink>
        )
      }
    </h2>
    {
      description && (
        <p class="text-muted-foreground m-0 text-sm leading-6">{description}</p>
      )
    }
  </div>
  <CompactEntryList
    items={items}
    emptyText={emptyText ?? "Items will appear here."}
    ordered={ordered}
    rowTitleLevel={3}
    showDescription={showDescription}
  />
</section>

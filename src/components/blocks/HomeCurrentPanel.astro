---
import CompactEntryPanel from "./CompactEntryPanel.astro";
import type { CompactEntryItem } from "../articles/compact-entry";

interface HomeCurrentLink {
  description?: string | undefined;
  href: string;
  label: string;
}

interface Props {
  description?: string;
  links: readonly HomeCurrentLink[];
  title?: string;
}

const {
  description = "Current project, community, and support paths.",
  links,
  title = "What’s Current",
} = Astro.props;
const items: CompactEntryItem[] = links.map((link) => ({
  description: link.description,
  href: link.href,
  prefetch: link.href.startsWith("/") ? "hover" : undefined,
  title: link.label,
}));
---

<CompactEntryPanel
  description={description}
  emptyText="Current updates will appear here."
  headingId="home-current-heading"
  items={items}
  ordered={false}
  showDescription
  title={title}
  data-home-current-panel
/>

---
import type { HTMLAttributes } from "astro/types";

import TermRailCard from "./TermRailCard.astro";
import ScrollRail from "../ui/ScrollRail.astro";

interface TermRailItem {
  count: number;
  description?: string | undefined;
  href: string;
  title: string;
}

interface Props extends HTMLAttributes<"section"> {
  emptyText?: string;
  itemNoun?: string;
  itemNounPlural?: string;
  items: readonly TermRailItem[];
  nextLabel?: string;
  previousLabel?: string;
  railId?: string;
  title?: string;
}

const {
  emptyText = "No terms are available yet.",
  itemNoun = "article",
  itemNounPlural = `${itemNoun}s`,
  items,
  nextLabel = "Scroll terms right",
  previousLabel = "Scroll terms left",
  railId = "term-rail",
  title = "Terms",
  class: className,
  "aria-label": ariaLabel,
  ...attrs
} = Astro.props;
const sectionLabel = ariaLabel ?? title;
---

<section
  {...attrs}
  class:list={["grid min-w-0 gap-4", className]}
  aria-label={sectionLabel}
  data-term-rail
>
  {
    items.length > 0 ? (
      <ScrollRail
        railId={railId}
        previousLabel={previousLabel}
        nextLabel={nextLabel}
      >
        {items.map((item) => (
          <TermRailCard
            count={item.count}
            description={item.description}
            href={item.href}
            pluralLabel={itemNounPlural}
            singularLabel={itemNoun}
            title={item.title}
          />
        ))}
      </ScrollRail>
    ) : (
      <p class="text-muted-foreground text-sm" data-term-rail-empty>
        {emptyText}
      </p>
    )
  }
</section>

---
import { ChevronLeft, ChevronRight } from "lucide-astro";

import IconButton from "../ui/IconButton.astro";

interface Props {
  itemCount: number;
  title?: string;
}

const { itemCount, title = "Featured" } = Astro.props;
const hasItems = itemCount > 0;
const hasMultipleItems = itemCount > 1;
---

<section
  class="grid min-w-0 gap-4 lg:h-full lg:grid-rows-[auto_minmax(0,1fr)_auto]"
  aria-labelledby="home-featured-heading"
  data-home-featured-carousel
>
  <div class="flex min-w-0 items-center justify-between gap-3">
    <h2
      id="home-featured-heading"
      class="text-foreground m-0 text-2xl font-semibold tracking-normal"
    >
      {title}
    </h2>
    {
      hasMultipleItems && (
        <div class="items-center gap-1" data-home-featured-controls hidden>
          <IconButton
            label="Previous featured item"
            size="sm"
            variant="ghost"
            data-home-featured-previous
          >
            <ChevronLeft class="size-4" aria-hidden="true" />
          </IconButton>
          <IconButton
            label="Next featured item"
            size="sm"
            variant="ghost"
            data-home-featured-next
          >
            <ChevronRight class="size-4" aria-hidden="true" />
          </IconButton>
        </div>
      )
    }
  </div>
  {
    hasItems ? (
      <>
        <div
          class="border-border grid min-h-80 min-w-0 content-center border-y py-4 lg:h-full lg:min-h-0"
          data-home-featured-viewport
          aria-live="polite"
        >
          <slot />
        </div>
        {hasMultipleItems && (
          <div
            class="min-w-0 items-center gap-2"
            data-home-featured-indicators
            hidden
          >
            {Array.from({ length: itemCount }, (_, index) => (
              <button
                type="button"
                class="bg-muted text-muted-foreground focus-visible:outline-ring aria-current:bg-primary size-2 rounded-full border-0 p-0 transition-colors focus-visible:outline-2 focus-visible:outline-offset-2"
                aria-label={`Show featured item ${index + 1}`}
                aria-current={index === 0 ? "true" : undefined}
                data-home-featured-indicator
                data-home-featured-index={String(index)}
              />
            ))}
          </div>
        )}
      </>
    ) : (
      <p class="text-muted-foreground m-0 text-sm">
        Featured items will appear here.
      </p>
    )
  }
</section>

{hasMultipleItems && <script src="../../scripts/home-featured-carousel.ts" />}

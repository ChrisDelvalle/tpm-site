---
import HomeFeaturedCarouselControls from "./HomeFeaturedCarouselControls.astro";

interface Props {
  emptyText?: string;
  itemCount: number;
  title?: string;
}

const {
  emptyText = "Featured items will appear here.",
  itemCount,
  title = "Featured Articles",
} = Astro.props;
const hasItems = itemCount > 0;
const hasMultipleItems = itemCount > 1;
---

<section
  class="grid min-w-0 gap-4 lg:h-full lg:grid-rows-[minmax(0,1fr)_auto]"
  aria-label={title}
  data-home-featured-carousel
>
  {
    hasItems ? (
      <>
        <div
          class="border-border grid min-h-80 min-w-0 content-start border-y py-4 lg:h-full lg:min-h-0"
          data-home-featured-viewport
          aria-live="polite"
        >
          <slot />
        </div>
        {hasMultipleItems && (
          <HomeFeaturedCarouselControls itemCount={itemCount} />
        )}
      </>
    ) : (
      <p class="text-muted-foreground m-0 text-sm">{emptyText}</p>
    )
  }
</section>

{hasMultipleItems && <script src="../../scripts/home-featured-carousel.ts" />}

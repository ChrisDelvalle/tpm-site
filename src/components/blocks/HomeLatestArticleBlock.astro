---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

import ArticleCard from "../articles/ArticleCard.astro";
import type { ArticleListItem } from "../../lib/article-list";

interface Props {
  image: ImageMetadata;
  imageAlt: string;
  item?: ArticleListItem | undefined;
  title?: string;
}

const { image, imageAlt, item, title = "Most Recent Post" } = Astro.props;
---

<section class="grid max-w-3xl gap-4" aria-labelledby="home-latest-heading">
  <h2
    id="home-latest-heading"
    class="text-foreground m-0 text-2xl font-semibold tracking-normal"
  >
    {title}
  </h2>
  {
    item ? (
      <>
        <Image
          src={image}
          alt={imageAlt}
          layout="full-width"
          class="block h-auto w-full rounded-sm"
        />
        <ArticleCard {...item} />
      </>
    ) : (
      <p class="text-muted-foreground">No published articles yet.</p>
    )
  }
</section>

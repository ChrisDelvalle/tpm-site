---
import CategorySidebar from "../navigation/CategorySidebar.astro";
import type { SectionNavItem } from "../../lib/navigation";

interface Props {
  navigationItems: readonly SectionNavItem[];
}

const { navigationItems } = Astro.props;
---

<div class="grid min-h-0 flex-1 lg:grid-cols-[18rem_minmax(0,1fr)]">
  <div class="hidden lg:block">
    <CategorySidebar items={navigationItems} />
  </div>
  <main id="content" class="min-w-0">
    <slot />
  </main>
</div>

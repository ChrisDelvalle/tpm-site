---
import BrandLink from "../navigation/BrandLink.astro";
import DiscoveryMenu from "../navigation/DiscoveryMenu.astro";
import MobileMenu from "../navigation/MobileMenu.astro";
import PrimaryNav from "../navigation/PrimaryNav.astro";
import SearchReveal from "../navigation/SearchReveal.astro";
import SupportLink from "../navigation/SupportLink.astro";
import ThemeToggle from "../navigation/ThemeToggle.astro";
import type { PrimaryNavItem, SectionNavItem } from "../../lib/navigation";

interface Props {
  categoryItems: readonly SectionNavItem[];
  currentPath: string;
  primaryItems: readonly PrimaryNavItem[];
}

const { categoryItems, currentPath, primaryItems } = Astro.props;
---

<header
  data-site-header
  class="border-border bg-background/95 sticky top-0 z-40 border-b backdrop-blur-sm"
>
  <div class="grid gap-2 px-4 py-3 lg:px-8" data-site-header-inner>
    <div
      class="grid grid-cols-[minmax(0,1fr)_auto_minmax(0,1fr)] items-center gap-3"
      data-site-header-primary-row
    >
      <div class="hidden min-w-0 items-center justify-start gap-1 md:flex">
        <SearchReveal />
        <ThemeToggle />
      </div>
      <div class="flex min-w-0 items-center justify-start md:hidden">
        <MobileMenu
          currentPath={currentPath}
          categoryItems={categoryItems}
          primaryItems={primaryItems}
        />
      </div>

      <div class="max-w-[42vw] min-w-0 justify-self-center md:max-w-none">
        <BrandLink />
      </div>

      <div class="flex min-w-0 items-center justify-end gap-2">
        <div class="hidden min-w-0 items-center md:flex">
          <PrimaryNav currentPath={currentPath} items={primaryItems} />
        </div>
        <SupportLink />
      </div>
    </div>

    <div
      class="hidden h-7 min-w-0 items-center justify-center md:flex"
      data-site-header-category-row
    >
      <DiscoveryMenu currentPath={currentPath} items={categoryItems} />
    </div>
  </div>
  <script src="../../scripts/site-header-offset.ts"></script>
</header>

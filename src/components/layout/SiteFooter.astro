---
import SupportLink from "../navigation/SupportLink.astro";
import TextLink from "../ui/TextLink.astro";
import type { SectionNavItem } from "../../lib/navigation";
import { SITE_DESCRIPTION, SITE_TITLE } from "../../lib/routes";
import { siteConfig } from "../../lib/site-config";

interface Props {
  navigationItems: readonly SectionNavItem[];
}

const { navigationItems } = Astro.props;
const footerCategories = navigationItems.slice(0, 8);
const footerLinks = siteConfig.navigation.footer;
---

<footer class="border-border bg-muted/40 border-t px-4 py-8 lg:px-8">
  <div class="mx-auto grid max-w-6xl gap-8 md:grid-cols-[minmax(0,1fr)_auto]">
    <div class="grid gap-4">
      <div>
        <p class="text-foreground font-semibold">{SITE_TITLE}</p>
        <p class="text-muted-foreground mt-1 max-w-prose text-sm">
          {SITE_DESCRIPTION}
        </p>
      </div>
      <nav aria-label="Footer navigation">
        <ul class="flex flex-wrap gap-x-4 gap-y-2 text-sm">
          {
            footerLinks.map((link) => (
              <li>
                <TextLink href={link.href} variant="subtle" tone="muted">
                  {link.label}
                </TextLink>
              </li>
            ))
          }
        </ul>
      </nav>
      <nav aria-label="Footer category navigation">
        <ul class="flex flex-wrap gap-x-3 gap-y-2 text-xs">
          {
            footerCategories.map((category) => (
              <li>
                <TextLink href={category.href} variant="subtle" tone="muted">
                  {category.title}
                </TextLink>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>
    <div class="self-start">
      <SupportLink label="Support Our Research" />
    </div>
  </div>
</footer>

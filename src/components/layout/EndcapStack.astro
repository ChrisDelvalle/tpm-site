---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"div"> {
  spacing?: "normal" | "relaxed";
}

const { spacing = "normal", class: className, ...attrs } = Astro.props;
const spacingClasses = {
  normal: "gap-6",
  relaxed: "gap-8 lg:gap-10",
} as const;
---

<div
  {...attrs}
  data-endcap-stack
  class:list={["mt-12 grid min-w-0", spacingClasses[spacing], className]}
>
  {Astro.slots.has("support") && <slot name="support" />}
  {Astro.slots.has("discovery") && <slot name="discovery" />}
  {Astro.slots.has("references") && <slot name="references" />}
  {Astro.slots.has("metadata") && <slot name="metadata" />}
  <slot />
</div>

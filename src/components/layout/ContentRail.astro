---
import type { HTMLAttributes } from "astro/types";

interface Props extends HTMLAttributes<"aside"> {
  label?: string | undefined;
  position: "left" | "right";
  sticky?: "below-header" | "none";
}

const {
  label,
  position,
  sticky = "none",
  class: className,
  ...attrs
} = Astro.props;

const stickyClasses =
  sticky === "below-header"
    ? "2xl:sticky 2xl:top-[calc(var(--site-header-height,4rem)+theme(spacing.6))] 2xl:max-h-[calc(100dvh-var(--site-header-height,4rem)-theme(spacing.12))] 2xl:overflow-y-auto"
    : "";
---

{
  Astro.slots.has("default") && (
    <aside
      {...attrs}
      aria-label={label}
      data-content-rail={position}
      class:list={[
        "text-muted-foreground min-w-0 text-sm",
        stickyClasses,
        className,
      ]}
    >
      <slot />
    </aside>
  )
}

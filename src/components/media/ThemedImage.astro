---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
  alt: string;
  class?: string;
  darkImage: ImageMetadata;
  fetchpriority?: "auto" | "high" | "low";
  layout?: "constrained" | "fixed" | "full-width";
  lightImage: ImageMetadata;
  loading?: "eager" | "lazy";
}

const {
  alt,
  class: className,
  darkImage,
  fetchpriority,
  layout = "constrained",
  lightImage,
  loading,
} = Astro.props;
---

<Image
  src={lightImage}
  alt={alt}
  layout={layout}
  loading={loading}
  fetchpriority={fetchpriority}
  class:list={["block dark:hidden", className]}
/>
<Image
  src={darkImage}
  alt={alt}
  layout={layout}
  loading={loading}
  fetchpriority={fetchpriority}
  class:list={["hidden dark:block", className]}
/>

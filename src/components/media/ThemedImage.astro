---
import type { ImageMetadata } from "astro";
import { Image } from "astro:assets";

interface Props {
  alt: string;
  class?: string;
  darkImage: ImageMetadata;
  fetchpriority?: "auto" | "high" | "low";
  layout?: "constrained" | "fixed" | "full-width";
  lightImage: ImageMetadata;
  loading?: "eager" | "lazy";
  priorityVariant?: "both" | "dark" | "light";
  sizes?: string;
}

const {
  alt,
  class: className,
  darkImage,
  fetchpriority,
  layout = "constrained",
  lightImage,
  loading,
  priorityVariant = "light",
  sizes,
} = Astro.props;

const lightIsPriority =
  priorityVariant === "light" || priorityVariant === "both";
const darkIsPriority = priorityVariant === "dark" || priorityVariant === "both";
const loadingFor = (isPriority: boolean) =>
  isPriority || loading !== "eager" ? loading : "lazy";
const fetchPriorityFor = (isPriority: boolean) =>
  isPriority || fetchpriority !== "high" ? fetchpriority : "low";
---

<Image
  src={lightImage}
  alt={alt}
  layout={layout}
  loading={loadingFor(lightIsPriority)}
  fetchpriority={fetchPriorityFor(lightIsPriority)}
  sizes={sizes}
  class:list={["block dark:hidden", className]}
/>
<Image
  src={darkImage}
  alt={alt}
  layout={layout}
  loading={loadingFor(darkIsPriority)}
  fetchpriority={fetchPriorityFor(darkIsPriority)}
  sizes={sizes}
  class:list={["hidden dark:block", className]}
/>

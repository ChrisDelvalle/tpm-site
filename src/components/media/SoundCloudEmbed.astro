---
import type { HTMLAttributes } from "astro/types";

import {
  embedFrameClassName,
  embedIframeClassName,
  soundCloudPlayerUrl,
} from "../../lib/embed-media";

type IframeAttributes = Omit<
  HTMLAttributes<"iframe">,
  "allow" | "class" | "scrolling" | "src" | "title"
>;

/** Public props for compact SoundCloud audio player embeds. */
interface Props extends IframeAttributes {
  class?: string | undefined;
  iframeClass?: string | undefined;
  sourceUrl?: string | undefined;
  src?: string | undefined;
  title: string;
}

const {
  src,
  sourceUrl,
  title,
  class: className,
  iframeClass,
  loading = "lazy",
  ...attrs
} = Astro.props;
const playerSrc =
  src ?? (sourceUrl === undefined ? undefined : soundCloudPlayerUrl(sourceUrl));

if (playerSrc === undefined || playerSrc.trim() === "") {
  throw new Error("SoundCloudEmbed requires either src or sourceUrl.");
}

const displayTitle = title.trim() === "" ? playerSrc : title;
---

<figure data-article-embed="true" class:list={["my-8 grid gap-2", className]}>
  <div
    class:list={[embedFrameClassName("audio"), "overflow-hidden rounded-sm"]}
    data-article-embed-frame="true"
    data-article-embed-provider="soundcloud"
    data-pdf-exclude="true"
  >
    <iframe
      {...attrs}
      src={playerSrc}
      title={title}
      loading={loading}
      scrolling="no"
      allow="autoplay"
      allowfullscreen={false}
      data-pdf-exclude="true"
      class:list={[embedIframeClassName("audio"), iframeClass]}></iframe>
  </div>
  <figcaption
    class="text-muted-foreground hidden text-sm print:block"
    data-article-embed-fallback="true"
  >
    Embedded media: <a href={playerSrc}>{displayTitle}</a>
  </figcaption>
</figure>
